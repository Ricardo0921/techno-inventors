---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---

<BaseLayout
  title="After School Program | Techno Inventors Puerto Rico"
  description="Tardes con propósito: ciencia, robótica y programación para niños y jóvenes en Puerto Rico. Tu hijo pasa de usar tecnología a crearla."
  ogTitle="After School — Techno Inventors"
  ogDescription="Programa after-school de lunes a viernes. Robótica, programación, diseño digital y más. Edades 6–18. Presencial y virtual."
  ogImage="/images/Ofrecimientos/After-School.webp"
>
  <Header activePage="programs" />

  <!-- HERO -->
  <section id="hero">
    <div class="hero-bg">
      <img src="/images/Ofrecimientos/After-School.webp" alt="After School Techno Inventors" loading="eager" />
      <div class="hero-overlay"></div>
    </div>
    <div class="container hero-content">
      <div class="hero-eyebrow">
        <span class="pill pill-blue" data-lang="es">📚 Lunes a Viernes · Presencial &amp; Virtual</span>
        <span class="pill pill-blue" data-lang="en">📚 Mon–Fri · In-person &amp; Virtual</span>
      </div>
      <h1>
        <span data-lang="es">Tardes con propósito:<br/><em>donde tus hijos pasan<br/>de usar tecnología a crearla</em></span>
        <span data-lang="en">Afternoons with purpose:<br/><em>where your kids go from<br/>using technology to building it</em></span>
      </h1>
      <p class="hero-sub">
        <span data-lang="es">After School Techno Inventors combina metodología STEAM con acompañamiento de mentores para que cada estudiante construya, programe y presente resultados concretos.</span>
        <span data-lang="en">After School Techno Inventors combines STEAM methodology with mentor support so every student builds, programs, and presents concrete results.</span>
      </p>
      <div class="hero-pills">
        <span class="hero-feature">
          <span class="hf-icon">📍</span>
          <span data-lang="es"><strong>Ubicación:</strong> San Juan – Hato Rey · Virtual</span>
          <span data-lang="en"><strong>Location:</strong> San Juan – Hato Rey · Virtual</span>
        </span>
        <span class="hero-feature">
          <span class="hf-icon">🎯</span>
          <span data-lang="es"><strong>Enfoque:</strong> Proyectos guiados con resultados</span>
          <span data-lang="en"><strong>Approach:</strong> Guided projects with results</span>
        </span>
        <span class="hero-feature">
          <span class="hf-icon">🏆</span>
          <span data-lang="es"><strong>Edades:</strong> 6 a 18 años</span>
          <span data-lang="en"><strong>Ages:</strong> 6 to 18 years</span>
        </span>
      </div>
      <div class="hero-actions">
        <a href="#registro" class="btn btn-primary btn-lg">
          <span data-lang="es">🚀 Inscribir a mi hijo(a)</span>
          <span data-lang="en">🚀 Enroll My Child</span>
        </a>
        <a href="#programa" class="btn btn-outline-white">
          <span data-lang="es">Ver el programa →</span>
          <span data-lang="en">See the program →</span>
        </a>
      </div>
      <p class="hero-micro" data-lang="es">Plazas limitadas por grupo · Lunes a Viernes · Sesiones de 1–2 horas</p>
      <p class="hero-micro" data-lang="en">Limited spots per group · Mon–Fri · 1–2 hour sessions</p>
    </div>
  </section>

  <!-- OPEN HOUSE BANNER -->
  <section class="open-house-bar">
    <div class="container oh-inner">
      <div class="oh-icon">🏠</div>
      <div class="oh-text">
        <strong data-lang="es">Open House (semanal) — Conoce el programa sin compromiso</strong>
        <strong data-lang="en">Open House (weekly) — See the program, no commitment</strong>
        <p data-lang="es">Todos los sábados ofrecemos un Open House donde padres e hijos pueden conocer más sobre nuestro programa, participar en demostraciones prácticas y resolver sus dudas. Es la oportunidad perfecta para ver de cerca cómo creamos Inventors tecnológicos desde temprana edad.</p>
        <p data-lang="en">Every Saturday we offer an Open House where parents and children can learn more about our program, participate in demos, and get their questions answered. The perfect opportunity to see firsthand how we create young tech inventors.</p>
      </div>
      <a href="#registro" class="btn btn-navy oh-btn">
        <span data-lang="es">Reservar visita →</span>
        <span data-lang="en">Book a visit →</span>
      </a>
    </div>
  </section>

  <!-- QUÉ HACE DIFERENTE -->
  <section id="diferente" class="section section-white">
    <div class="container diff-grid">
      <div class="diff-img reveal">
        <img src="/images/desarrollo-profesional/IMG_0925.webp" alt="Estudiantes After School" loading="lazy" />
      </div>
      <div class="diff-text reveal">
        <span class="section-tag">¿Qué hace diferente a Techno Inventors?</span>
        <h2 class="section-title" data-lang="es">En Techno Inventors, la tecnología no es "da" — se construye</h2>
        <h2 class="section-title" data-lang="en">At Techno Inventors, technology isn't "given" — it's built</h2>
        <p data-lang="es">Nuestro enfoque combina metodología STEAM con acompañamiento de mentores para que cada estudiante desarrolle proyectos que refuerzan habilidades esenciales: lógica, creatividad, colaboración y comunicación.</p>
        <p data-lang="en">Our approach combines STEAM methodology with mentor support so each student develops projects that reinforce essential skills: logic, creativity, collaboration, and communication.</p>
        <p data-lang="es">Para familias, esto significa una alternativa educativa que aprovecha las tardes con estructura y motivación, donde cada estudiante es un individuo que avanza con el currículo, desarrolla proyectos, noche retroalimentación y fortalece su confianza como creador.</p>
        <p data-lang="en">For families, this means an educational alternative that makes afternoons productive—where each student advances individually, develops projects, receives feedback, and grows their confidence as a creator.</p>
        <a href="#registro" class="btn btn-primary" data-lang="es">📋 Recibir el plan recomendado</a>
        <a href="#registro" class="btn btn-primary" data-lang="en">📋 Get the recommended plan</a>
      </div>
    </div>
  </section>

  <!-- PROGRAMA -->
  <section id="programa" class="section section-light">
    <div class="container">
      <div class="text-center reveal">
        <span class="section-tag" data-lang="es">¿Qué es el programa After School?</span>
        <span class="section-tag" data-lang="en">What is the After School program?</span>
        <h2 class="section-title" data-lang="es">Un programa, tres rutas por etapa</h2>
        <h2 class="section-title" data-lang="en">One program, three tracks by stage</h2>
        <p class="section-subtitle" data-lang="es">En Techno Inventors adaptamos contenido, ritmo y tipo de reto según el desarrollo cognitivo y la experiencia previa. Así logramos que cada estudiante avance sin que el contenido no le quede grande ni pequeño.</p>
        <p class="section-subtitle" data-lang="en">At Techno Inventors we adapt content, pace, and challenge type to each student's cognitive development and prior experience. That way everyone advances without the content being too easy or too hard.</p>
      </div>
      <div class="rutas-grid">
        <div class="ruta-card reveal">
          <div class="ruta-age" data-lang="es">6–7 años<br/><small>Iniciación</small></div>
          <div class="ruta-age" data-lang="en">6–7 years<br/><small>Beginner</small></div>
          <p data-lang="es">Actividades cortas y variadas que guían a que desarrollen curiosidad, exploración y lógica básica a través del juego. Mucho movimiento, experimentos sencillos y aprendizaje lúdico.</p>
          <p data-lang="en">Short, varied activities that guide them to develop curiosity, exploration, and basic logic through play. Lots of movement, simple experiments, and fun learning.</p>
        </div>
        <div class="ruta-card ruta-card-featured reveal">
          <div class="ruta-popular" data-lang="es">⭐ Más solicitado</div>
          <div class="ruta-popular" data-lang="en">⭐ Most requested</div>
          <div class="ruta-age" data-lang="es">8–12 años<br/><small>Fundamentos</small></div>
          <div class="ruta-age" data-lang="en">8–12 years<br/><small>Foundations</small></div>
          <p data-lang="es">Proyectos más complejos, pensamiento crítico, programación y trabajo en equipo. Aprenden a construir, crear y presentar ideas con herramientas reales de tecnología.</p>
          <p data-lang="en">More complex projects, critical thinking, programming, and teamwork. They learn to build, create, and present ideas using real tech tools.</p>
        </div>
        <div class="ruta-card reveal">
          <div class="ruta-age" data-lang="es">13–18 años<br/><small>Avanzado / Pre-profesional</small></div>
          <div class="ruta-age" data-lang="en">13–18 years<br/><small>Advanced / Pre-professional</small></div>
          <p data-lang="es">Proyectos más completos, presentación de resultados y enfoque pre-profesional. Se impulsa la autonomía y la creación de un portafolio con resultados visibles.</p>
          <p data-lang="en">More complete projects, results presentation, and pre-professional focus. Autonomy is encouraged along with building a portfolio of visible results.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- MODALIDADES -->
  <section class="section section-navy">
    <div class="container">
      <div class="text-center reveal">
        <span class="section-tag section-tag-light" data-lang="es">Modalidades disponibles</span>
        <span class="section-tag section-tag-light" data-lang="en">Available formats</span>
        <h2 class="section-title section-title-light" data-lang="es">Presencial y Virtual</h2>
        <h2 class="section-title section-title-light" data-lang="en">In-Person and Virtual</h2>
      </div>
      <div class="modal-grid">
        <div class="modal-card reveal">
          <div class="modal-icon">📍</div>
          <h3 data-lang="es">Presencial<br/><small>San Juan – Hato Rey</small></h3>
          <h3 data-lang="en">In-Person<br/><small>San Juan – Hato Rey</small></h3>
          <p data-lang="es">Disfruta aprendizaje práctico con dinámica de grupo y demostraciones en vivo. La experiencia más completa e interactiva.</p>
          <p data-lang="en">Enjoy hands-on learning with group dynamics and live demonstrations. The most complete and interactive experience.</p>
        </div>
        <div class="modal-card reveal">
          <div class="modal-icon">💻</div>
          <h3>Virtual</h3>
          <p data-lang="es">Opción flexible con actividades guiadas, acompañamiento y retos adaptados para casa. Ideal para estudiantes fuera del área metropolitana.</p>
          <p data-lang="en">Flexible option with guided activities, support, and home-adapted challenges. Ideal for students outside the metro area.</p>
        </div>
        <div class="modal-card reveal">
          <div class="modal-icon">🏁</div>
          <h3 data-lang="es">Proyecto Final</h3>
          <h3 data-lang="en">Final Project</h3>
          <p data-lang="es">Al finalizar cada etapa, los estudiantes suelen contar con un proyecto final que pueden mostrar en casa, en la escuela o en una presentación sencilla. Eso crea motivación real y un sentido claro de avance.</p>
          <p data-lang="en">At the end of each stage, students typically have a final project they can show at home, at school, or in a simple presentation. This creates real motivation and a clear sense of progress.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- BENEFICIOS -->
  <section class="section section-white">
    <div class="container">
      <div class="text-center reveal">
        <span class="section-tag" data-lang="es">Beneficios principales — para padres y educadores</span>
        <span class="section-tag" data-lang="en">Key benefits — for parents and educators</span>
        <h2 class="section-title" data-lang="es">STEM · creatividad · confianza</h2>
        <h2 class="section-title" data-lang="en">STEM · creativity · confidence</h2>
      </div>
      <div class="benefits-grid">
        <div class="benefit-item reveal">
          <div class="benefit-icon">🎯</div>
          <div>
            <h4 data-lang="es">Habilidades STEM con propósito</h4>
            <h4 data-lang="en">Purpose-driven STEM skills</h4>
            <p data-lang="es">No memorizar. Aprender haciendo proyectos reales que pueden convertirse en algo concreto.</p>
            <p data-lang="en">No memorizing. Learning by doing real projects that become something concrete.</p>
          </div>
        </div>
        <div class="benefit-item reveal">
          <div class="benefit-icon">🧠</div>
          <div>
            <h4 data-lang="es">Pensamiento lógico y resolución de problemas</h4>
            <h4 data-lang="en">Logical thinking and problem solving</h4>
            <p data-lang="es">Aprenden a identificar errores, ajustar la solución y explicar su proceso.</p>
            <p data-lang="en">They learn to identify errors, adjust solutions, and explain their process.</p>
          </div>
        </div>
        <div class="benefit-item reveal">
          <div class="benefit-icon">🎨</div>
          <div>
            <h4 data-lang="es">Creatividad aplicada</h4>
            <h4 data-lang="en">Applied creativity</h4>
            <p data-lang="es">Diseñan, construyen y toman decisiones. La creatividad se trabaja como músculo.</p>
            <p data-lang="en">They design, build, and make decisions. Creativity is trained like a muscle.</p>
          </div>
        </div>
        <div class="benefit-item reveal">
          <div class="benefit-icon">🤝</div>
          <div>
            <h4 data-lang="es">Más confianza y autonomía</h4>
            <h4 data-lang="en">More confidence and autonomy</h4>
            <p data-lang="es">Pasan de consumidores pasivos a creadores activos. La confianza crece sesión tras sesión.</p>
            <p data-lang="en">They go from passive consumers to active creators. Confidence grows session by session.</p>
          </div>
        </div>
        <div class="benefit-item reveal">
          <div class="benefit-icon">💬</div>
          <div>
            <h4 data-lang="es">Comunicación y colaboración</h4>
            <h4 data-lang="en">Communication and collaboration</h4>
            <p data-lang="es">Trabajan en equipo, presentan sus ideas y aprenden a recibir retroalimentación.</p>
            <p data-lang="en">They work in teams, present ideas, and learn to receive feedback.</p>
          </div>
        </div>
        <div class="benefit-item reveal">
          <div class="benefit-icon">📊</div>
          <div>
            <h4 data-lang="es">Resultados visibles para familia y escuela</h4>
            <h4 data-lang="en">Visible results for family and school</h4>
            <p data-lang="es">Portafolios, proyectos completados y presentaciones demostrables.</p>
            <p data-lang="en">Portfolios, completed projects, and demonstrable presentations.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FOTOS -->
  <section class="section section-light">
    <div class="container">
      <div class="photos-grid">
        <img src="/images/desarrollo-profesional/IMG_0937.webp" alt="Estudiantes After School" loading="lazy" class="reveal" />
        <img src="/images/early-inventors/IMG_3263.webp" alt="Taller tecnología" loading="lazy" class="reveal" />
        <img src="/images/desarrollo-profesional/IMG_0954.webp" alt="Proyecto estudiantil" loading="lazy" class="reveal" />
      </div>
    </div>
  </section>

  <!-- TESTIMONIOS -->
  <section class="section section-white">
    <div class="container">
      <div class="text-center reveal">
        <span class="section-tag" data-lang="es">Familias y educadores en Puerto Rico comparten su experiencia</span>
        <span class="section-tag" data-lang="en">Families and educators in Puerto Rico share their experience</span>
      </div>
      <div class="testimonials-grid">
        <blockquote class="test-card reveal">
          <div class="test-stars">★★★★★</div>
          <p data-lang="es">"Mi hijo llegó contando a todo el mundo lo que había construido. Se fue volver a explicar por qué funciona y por qué."</p>
          <p data-lang="en">"My son came home telling everyone what he built. He kept going back to explain how and why it works."</p>
          <footer>— <strong data-lang="es">Madre, Rayamín</strong><strong data-lang="en">Mother, Rayamín</strong></footer>
        </blockquote>
        <blockquote class="test-card reveal">
          <div class="test-stars">★★★★★</div>
          <p data-lang="es">"Como escuela, nos sorprendió cómo los estudiantes explicaban sus proyectos con confianza. No es solo tecnología. Es formación integral."</p>
          <p data-lang="en">"As a school, we were amazed at how students explained their projects with confidence. It's not just technology. It's whole-child development."</p>
          <footer>— <strong data-lang="es">Educadora, área metro</strong><strong data-lang="en">Educator, metro area</strong></footer>
        </blockquote>
        <blockquote class="test-card reveal">
          <div class="test-stars">★★★★★</div>
          <p data-lang="es">"Me gustó que trabajaran por niveles. Mi hijo se sintió capaz, nunca perdido. El programa lo reta sin frustrarlo."</p>
          <p data-lang="en">"I liked that they worked by levels. My son felt capable, never lost. The program challenges without frustrating."</p>
          <footer>— <strong data-lang="es">Padre, Caguas</strong><strong data-lang="en">Father, Caguas</strong></footer>
        </blockquote>
      </div>
    </div>
  </section>

  <!-- REGISTRO -->
  <section id="registro" class="section section-cta">
    <div class="container">
      <div class="registro-box reveal">
        <div class="registro-icon">📋</div>
        <h2 data-lang="es">Plazas limitadas por grupo para cuidar la calidad del acompañamiento</h2>
        <h2 data-lang="en">Limited spots per group to maintain quality mentoring</h2>
        <p data-lang="es">Si quieres conocer la ruta recomendada según la edad y modalidad, déjanos tus datos.</p>
        <p data-lang="en">If you'd like to know the recommended track based on age and format, leave us your information.</p>
        <a href="#" class="btn btn-primary btn-lg btn-full">
          <span data-lang="es">🎓 Completar formulario de inscripción</span>
          <span data-lang="en">🎓 Complete enrollment form</span>
        </a>
        <p class="registro-note" data-lang="es">Te contactaremos en 24–48 horas hábiles con la orientación y el próximo paso.</p>
        <p class="registro-note" data-lang="en">We'll contact you within 24–48 business hours with guidance and next steps.</p>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>

<style>
  :root {
    --navy: #1A2156;
    --blue: #258EB6;
    --light-blue: #88D7F7;
    --white: #ffffff;
    --text: #374151;
    --border: rgba(26,33,86,0.1);
    --card-bg: #f8fafc;
    --radius: 12px;
    --radius-lg: 20px;
    --shadow: 0 4px 20px rgba(26,33,86,0.08);
    --transition: 0.3s ease;
    --font-display: 'Orbitron', sans-serif;
  }

  /* HERO */
  #hero { position: relative; min-height: 90vh; display: flex; align-items: center; overflow: hidden; }
  .hero-bg { position: absolute; inset: 0; }
  .hero-bg img { width: 100%; height: 100%; object-fit: cover; }
  .hero-overlay { position: absolute; inset: 0; background: linear-gradient(135deg, rgba(10,14,56,0.92) 0%, rgba(37,142,182,0.30) 100%); }
  .hero-content { position: relative; z-index: 2; padding: 120px 0 80px; max-width: 760px; }
  .hero-eyebrow { margin-bottom: 20px; }
  .pill { display: inline-block; border-radius: 50px; padding: 8px 20px; font-size: 0.8rem; font-weight: 700; letter-spacing: 1px; text-transform: uppercase; }
  .pill-blue { background: rgba(37,142,182,0.25); border: 1px solid rgba(136,215,247,0.4); color: var(--light-blue); }
  .pill-green { background: rgba(37,142,182,0.25); border: 1px solid rgba(136,215,247,0.4); color: var(--light-blue); }
  h1 { font-family: var(--font-display); font-size: clamp(2rem, 5vw, 3.2rem); font-weight: 900; color: var(--white); line-height: 1.2; margin-bottom: 20px; }
  h1 em { color: var(--light-blue); font-style: normal; }
  .hero-sub { color: rgba(255,255,255,0.78); font-size: 1.05rem; max-width: 600px; margin-bottom: 28px; line-height: 1.7; }
  .hero-pills { display: flex; flex-wrap: wrap; gap: 12px; margin-bottom: 32px; }
  .hero-feature { display: flex; align-items: center; gap: 10px; background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.15); border-radius: 50px; padding: 8px 16px; color: var(--white); font-size: 0.82rem; }
  .hf-icon { font-size: 1.1rem; }
  .hero-actions { display: flex; gap: 14px; flex-wrap: wrap; margin-bottom: 20px; }
  .hero-micro { color: rgba(255,255,255,0.45); font-size: 0.78rem; }

  /* OPEN HOUSE */
  .open-house-bar { background: linear-gradient(135deg, #fef9c3, #fef08a); border-top: 3px solid #eab308; border-bottom: 3px solid #eab308; padding: 28px 0; }
  .oh-inner { display: flex; align-items: flex-start; gap: 20px; flex-wrap: wrap; }
  .oh-icon { font-size: 2.5rem; flex-shrink: 0; }
  .oh-text { flex: 1; min-width: 200px; }
  .oh-text strong { display: block; font-size: 1rem; color: var(--navy); margin-bottom: 8px; }
  .oh-text p { font-size: 0.88rem; color: #374151; margin: 0; }
  .oh-btn { flex-shrink: 0; align-self: center; }

  /* BUTTONS */
  .btn { display: inline-flex; align-items: center; gap: 8px; padding: 14px 28px; border-radius: 50px; font-weight: 700; font-size: 0.9rem; cursor: pointer; transition: var(--transition); border: 2px solid transparent; text-decoration: none; white-space: nowrap; }
  .btn-primary { background: linear-gradient(135deg, var(--blue), #1a6f95); color: var(--white); border-color: var(--blue); box-shadow: 0 4px 20px rgba(37,142,182,0.4); }
  .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 8px 28px rgba(37,142,182,0.55); }
  .btn-navy { background: var(--navy); color: var(--white); border-color: var(--navy); }
  .btn-navy:hover { background: #242d7a; transform: translateY(-2px); }
  .btn-outline-white { background: transparent; color: var(--white); border-color: rgba(255,255,255,0.5); }
  .btn-outline-white:hover { background: rgba(255,255,255,0.1); border-color: var(--white); }
  .btn-lg { padding: 18px 40px; font-size: 1rem; }
  .btn-full { width: 100%; justify-content: center; }

  /* SECTIONS */
  .section { padding: 88px 0; }
  .section-white { background: var(--white); }
  .section-light { background: #f0f4f8; }
  .section-navy { background: linear-gradient(135deg, #0a0e2e, var(--navy)); }
  .section-cta { background: linear-gradient(135deg, var(--navy), #258EB6); }
  .section-tag { display: inline-block; background: rgba(37,142,182,0.12); color: var(--blue); border: 1px solid rgba(37,142,182,0.3); border-radius: 50px; padding: 6px 18px; font-size: 0.75rem; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; margin-bottom: 16px; }
  .section-tag-light { background: rgba(136,215,247,0.15); color: var(--light-blue); border-color: rgba(136,215,247,0.3); }
  .section-title { font-family: var(--font-display); color: var(--navy); font-size: clamp(1.6rem, 3.5vw, 2.4rem); font-weight: 900; margin-bottom: 16px; line-height: 1.2; }
  .section-title-light { color: var(--white); }
  .section-subtitle { color: #6b7280; font-size: 1rem; max-width: 680px; margin: 0 auto 48px; line-height: 1.7; }
  .text-center { text-align: center; }

  /* DIFF SECTION */
  .diff-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 64px; align-items: center; }
