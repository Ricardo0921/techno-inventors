---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---

<BaseLayout
  title="Summer Camp | Techno Inventors Puerto Rico"
  description="Summer Camp Techno Inventors: un verano para crear tecnología, no solo usarla. Robótica, videojuegos, programación e IA. Edades 3–18. Presencial y virtual."
  ogTitle="Summer Camp — Techno Inventors"
  ogDescription="Este verano vive el Summer Camp de Techno Inventors en Puerto Rico. Una experiencia educativa, práctica y divertida. Edades 3–18 años."
  ogImage="/images/Ofrecimientos/Summer-Camp.webp"
>
  <Header activePage="programs" />

  <section id="hero">
    <div class="hero-bg">
      <img src="/images/Ofrecimientos/Summer-Camp.webp" alt="Summer Camp Techno Inventors" loading="eager" />
      <div class="hero-overlay"></div>
    </div>
    <div class="container hero-content">
      <div class="hero-eyebrow">
        <span class="pill" data-lang="es">☀️ Junio – Agosto · Presencial &amp; Virtual</span>
        <span class="pill" data-lang="en">☀️ June – August · In-person &amp; Virtual</span>
      </div>
      <h1>
        <span data-lang="es">Un verano para <em>crear tecnología</em><br/>—no solo usarla—</span>
        <span data-lang="en">A summer to <em>build technology</em><br/>—not just use it—</span>
      </h1>
      <p class="hero-sub">
        <span data-lang="es">Este verano vive el Summer Camp de Techno Inventors en Puerto Rico: una experiencia educativa, práctica y divertida donde niños y jóvenes desarrollan habilidades tecnológicas a través de proyectos reales en STEAM, robótica, videojuegos y eSports.</span>
        <span data-lang="en">This summer, experience Techno Inventors Summer Camp in Puerto Rico: an educational, hands-on, and fun experience where kids and teens build tech skills through real projects in STEAM, robotics, video games, and eSports.</span>
      </p>
      <div class="hero-pills">
        <span class="hero-feature"><span class="hf-icon">📍</span><span data-lang="es"><strong>Modalidad:</strong> Presencial y Virtual</span><span data-lang="en"><strong>Format:</strong> In-Person &amp; Virtual</span></span>
        <span class="hero-feature"><span class="hf-icon">🎯</span><span data-lang="es"><strong>Enfoque:</strong> Aprender haciendo, por niveles</span><span data-lang="en"><strong>Approach:</strong> Learning by doing, by level</span></span>
        <span class="hero-feature"><span class="hf-icon">👨‍👩‍👧</span><span data-lang="es"><strong>Para padres:</strong> Guía para elegir el programa ideal</span><span data-lang="en"><strong>For parents:</strong> Guide to choose the ideal program</span></span>
      </div>
      <div class="hero-actions">
        <a href="#registro" class="btn btn-primary btn-lg">
          <span data-lang="es">🚀 Inscribir a mi hijo(a)</span>
          <span data-lang="en">🚀 Enroll My Child</span>
        </a>
        <a href="#programa" class="btn btn-outline-white">
          <span data-lang="es">Ver el campamento →</span>
          <span data-lang="en">See the camp →</span>
        </a>
      </div>
      <p class="hero-micro" data-lang="es">Plazas limitadas · Verano de resultados reales · Edades 3–18 años</p>
      <p class="hero-micro" data-lang="en">Limited spots · Summer of real results · Ages 3–18</p>
    </div>
  </section>

  <!-- HIGHLIGHT BANNER -->
  <div class="highlight-bar">
    <div class="container">
      <p data-lang="es">☀️ <strong>Aprender haciendo, con resultados visibles.</strong> Como padre o tutor, buscas más que "entretenimiento ocupado"; quieres un espacio que desarrolle pensamiento lógico, creatividad y confianza.</p>
      <p data-lang="en">☀️ <strong>Learning by doing, with visible results.</strong> As a parent or guardian, you want more than "busy entertainment"; you want a space that develops logical thinking, creativity, and confidence.</p>
    </div>
  </div>

  <!-- QUÉ ES -->
  <section id="programa" class="section section-white">
    <div class="container">
      <div class="text-center reveal">
        <span class="section-tag" data-lang="es">¿Qué es el Summer Camp y cómo se vive?</span>
        <span class="section-tag" data-lang="en">What is the Summer Camp and how does it work?</span>
        <h2 class="section-title" data-lang="es">Modalidad Virtual y Presencial</h2>
        <h2 class="section-title" data-lang="en">Virtual and In-Person Format</h2>
        <p class="section-subtitle" data-lang="es">El Summer Camp de Techno Inventors es un campamento educativo con rutas por edad y nivel, diseñado para que los estudiantes exploren, construyan, programen y presenten.</p>
        <p class="section-subtitle" data-lang="en">The Techno Inventors Summer Camp is an educational camp with tracks by age and level, designed for students to explore, build, program, and present.</p>
      </div>
      <div class="activities-grid">
        <div class="act-card reveal"><div class="act-icon">🤖</div><h4 data-lang="es">Robótica educativa</h4><h4 data-lang="en">Educational Robotics</h4><p data-lang="es">Construcción, sensores, motores de movimiento, lógica y resolución de problemas.</p><p data-lang="en">Construction, sensors, motion motors, logic, and problem solving.</p></div>
        <div class="act-card reveal"><div class="act-icon">💻</div><h4 data-lang="es">Programación computacional</h4><h4 data-lang="en">Computational Programming</h4><p data-lang="es">Desde programación visual por bloques hasta estructuras más avanzadas.</p><p data-lang="en">From visual block programming to more advanced structures.</p></div>
        <div class="act-card reveal"><div class="act-icon">🎮</div><h4 data-lang="es">Creación digital y videojuegos</h4><h4 data-lang="en">Digital Creation &amp; Video Games</h4><p data-lang="es">Diseño de personajes y escenarios, mecánicas, prototipos jugables y presentación del del nivel.</p><p data-lang="en">Character and scene design, mechanics, playable prototypes, and level presentation.</p></div>
        <div class="act-card reveal"><div class="act-icon">🤝</div><h4 data-lang="es">Retos colaborativos</h4><h4 data-lang="en">Collaborative Challenges</h4><p data-lang="es">Trabajo en equipo, comunicación y multidisciplinaridad, y demostraciones de avances.</p><p data-lang="en">Teamwork, communication, and interdisciplinary demos of progress.</p></div>
        <div class="act-card reveal"><div class="act-icon">🏁</div><h4 data-lang="es">Proyecto final</h4><h4 data-lang="en">Final Project</h4><p data-lang="es">Robot funcional, prototipo interactivo o proyecto digital con explicación del proceso.</p><p data-lang="en">Functional robot, interactive prototype, or digital project with process explanation.</p></div>
      </div>
      <div class="text-center" style="margin-top:40px;">
        <a href="#registro" class="btn btn-primary" data-lang="es">📋 Plan personalizado</a>
        <a href="#registro" class="btn btn-primary" data-lang="en">📋 Personalized plan</a>
      </div>
    </div>
  </section>

  <!-- RUTAS -->
  <section class="section section-light">
    <div class="container">
      <div class="text-center reveal">
        <span class="section-tag" data-lang="es">Edades participantes</span>
        <span class="section-tag" data-lang="en">Participating ages</span>
        <h2 class="section-title" data-lang="es">De 3 a 18 años — con rutas por etapa</h2>
        <h2 class="section-title" data-lang="en">Ages 3 to 18 — with tracks by stage</h2>
        <p class="section-subtitle" data-lang="es">En Techno Inventors adaptamos contenido, ritmo y tipo de reto según el desarrollo cognitivo y la experiencia previa.</p>
        <p class="section-subtitle" data-lang="en">At Techno Inventors we adapt content, pace, and challenge type to each student's cognitive development and prior experience.</p>
      </div>
      <div class="rutas-grid">
        <div class="ruta-card reveal"><div class="ruta-age" data-lang="es">3–5 años<br/><small>Iniciación</small></div><div class="ruta-age" data-lang="en">3–5 years<br/><small>Beginner</small></div><p data-lang="es">Construcción, curiosidad, secuencias y lógica básica a través del juego.</p><p data-lang="en">Building, curiosity, sequences, and basic logic through play.</p></div>
        <div class="ruta-card ruta-card-featured reveal"><div class="ruta-popular" data-lang="es">⭐ Más solicitado</div><div class="ruta-popular" data-lang="en">⭐ Most requested</div><div class="ruta-age" data-lang="es">6–12 años<br/><small>Fundamentos</small></div><div class="ruta-age" data-lang="en">6–12 years<br/><small>Foundations</small></div><p data-lang="es">Proyectos más complejos, programación, construcción y retos por niveles (lo típico para esta etapa).</p><p data-lang="en">More complex projects, programming, construction, and level-based challenges (typical for this stage).</p></div>
        <div class="ruta-card reveal"><div class="ruta-age" data-lang="es">13–18 años<br/><small>Avanzado / Pre-profesional</small></div><div class="ruta-age" data-lang="en">13–18 years<br/><small>Advanced / Pre-professional</small></div><p data-lang="es">Diseño de proyectos más completos, presentación de resultados y enfoque pre-profesional con portafolio.</p><p data-lang="en">More complete project design, results presentation, and pre-professional portfolio focus.</p></div>
      </div>
    </div>
  </section>

  <!-- BENEFICIOS -->
  <section class="section section-navy">
    <div class="container">
      <div class="text-center reveal">
        <span class="section-tag section-tag-light" data-lang="es">Beneficios principales — para estudiantes y tranquilidad para ti</span>
        <span class="section-tag section-tag-light" data-lang="en">Key benefits — for students and peace of mind for you</span>
        <h2 class="section-title section-title-light">STEM · creatividad · confianza</h2>
      </div>
      <div class="benefits-grid">
        <div class="benefit-item reveal"><div class="benefit-icon">🎯</div><div><h4 data-lang="es">Habilidades STEM con propósito</h4><h4 data-lang="en">Purpose-driven STEM skills</h4><p data-lang="es">No memorizar. Aprender haciendo proyectos reales que pueden convertirse en algo concreto.</p><p data-lang="en">No memorizing. Learning through real projects that become something tangible.</p></div></div>
        <div class="benefit-item reveal"><div class="benefit-icon">🧠</div><div><h4 data-lang="es">Pensamiento lógico y resolución de problemas</h4><h4 data-lang="en">Logical thinking &amp; problem solving</h4><p data-lang="es">Aprenden a identificar errores, ajustar y explicar su proceso.</p><p data-lang="en">They learn to identify errors, adjust, and explain their process.</p></div></div>
        <div class="benefit-item reveal"><div class="benefit-icon">🎨</div><div><h4 data-lang="es">Creatividad aplicada</h4><h4 data-lang="en">Applied creativity</h4><p data-lang="es">Diseñan, construyen y toman decisiones. La creatividad se trabaja como músculo.</p><p data-lang="en">They design, build, and make decisions. Creativity is trained like a muscle.</p></div></div>
        <div class="benefit-item reveal"><div class="benefit-icon">🤝</div><div><h4 data-lang="es">Más confianza y autonomía</h4><h4 data-lang="en">More confidence &amp; autonomy</h4><p data-lang="es">Pasan de consumidores pasivos a creadores activos.</p><p data-lang="en">They go from passive consumers to active creators.</p></div></div>
        <div class="benefit-item reveal"><div class="benefit-icon">💬</div><div><h4 data-lang="es">Comunicación y colaboración</h4><h4 data-lang="en">Communication &amp; collaboration</h4><p data-lang="es">Trabajan en equipo, presentan ideas y aprenden a recibir retroalimentación.</p><p data-lang="en">They work in teams, present ideas, and learn to receive feedback.</p></div></div>
        <div class="benefit-item reveal"><div class="benefit-icon">📊</div><div><h4 data-lang="es">Resultados visibles para familia</h4><h4 data-lang="en">Visible results for family</h4><p data-lang="es">Portafolios, proyectos completados y presentaciones demostrables.</p><p data-lang="en">Portfolios, completed projects, and demonstrable presentations.</p></div></div>
      </div>
    </div>
  </section>

  <!-- FOTOS -->
  <section class="section section-white">
    <div class="container">
      <div class="photos-grid">
        <img src="/images/camps/IMG_3285.webp" alt="Summer Camp actividad" loading="lazy" class="reveal" />
        <img src="/images/camps/IMG_3283.webp" alt="Proyectos summer camp" loading="lazy" class="reveal" />
        <img src="/images/early-inventors/IMG_3261.webp" alt="Tecnología en acción" loading="lazy" class="reveal" />
      </div>
    </div>
  </section>

  <!-- TESTIMONIOS -->
  <section class="section section-light">
    <div class="container">
      <div class="text-center reveal">
        <span class="section-tag" data-lang="es">Familias y educadores en Puerto Rico comparten su experiencia</span>
        <span class="section-tag" data-lang="en">Families and educators in Puerto Rico share their experience</span>
      </div>
      <div class="testimonials-grid">
        <blockquote class="test-card reveal"><div class="test-stars">★★★★★</div><p data-lang="es">"Mi hijo salió hablando de su proyecto todo el camino a casa. Lo mejor fue ver lo que fue volver a explicar lo que hizo y por qué."</p><p data-lang="en">"My son talked about his project the whole way home. The best part was watching him explain what he did and why."</p><footer>— <strong data-lang="es">Madre de participante (6–12)</strong><strong data-lang="en">Mother of participant (6–12)</strong></footer></blockquote>
        <blockquote class="test-card reveal"><div class="test-stars">★★★★★</div><p data-lang="es">"Me gustó la estructura. No es solo 'jugar con tecnología'. Hay metas claras, seguimiento y acompañamiento."</p><p data-lang="en">"I loved the structure. It's not just 'playing with technology'. There are clear goals, tracking, and support."</p><footer>— <strong data-lang="es">Padre de participante (3–5)</strong><strong data-lang="en">Father of participant (3–5)</strong></footer></blockquote>
        <blockquote class="test-card reveal"><div class="test-stars">★★★★★</div><p data-lang="es">"Como educadora, valoro que practiquen lógica y creatividad a la vez. Se nota el progreso por temporadas."</p><p data-lang="en">"As an educator, I love that they practice logic and creativity simultaneously. Progress is visible each season."</p><footer>— <strong data-lang="es">Maestra (13–18)</strong><strong data-lang="en">Teacher (13–18)</strong></footer></blockquote>
      </div>
    </div>
  </section>

  <!-- ¿No estás seguro? -->
  <section class="section section-navy">
    <div class="container text-center reveal">
      <h2 class="section-title section-title-light" data-lang="es">¿No estás seguro si la robótica o los videojuegos es mejor para su edad?</h2>
      <h2 class="section-title section-title-light" data-lang="en">Not sure if robotics or video games is better for their age?</h2>
      <p style="color:rgba(255,255,255,0.7);max-width:560px;margin:0 auto 32px;" data-lang="es">En lugar de adivinar, cuéntanos lo esencial y te ayudamos a identificar la ruta más adecuada según edad y modalidad preferida.</p>
      <p style="color:rgba(255,255,255,0.7);max-width:560px;margin:0 auto 32px;" data-lang="en">Instead of guessing, tell us the essentials and we'll help you identify the right track based on age and preferred format.</p>
      <a href="#registro" class="btn btn-primary btn-lg" data-lang="es">🎯 Identificar la ruta ideal</a>
      <a href="#registro" class="btn btn-primary btn-lg" data-lang="en">🎯 Find the ideal track</a>
    </div>
  </section>

  <!-- REGISTRO -->
  <section id="registro" class="section section-cta">
    <div class="container">
      <div class="registro-box reveal">
        <div class="registro-icon">🏕️</div>
        <h2 data-lang="es">Formulario de registro para el Campamento de Verano</h2>
        <h2 data-lang="en">Summer Camp Registration Form</h2>
        <p data-lang="es">Completa el formulario y nuestro equipo te contactará para confirmar edad, modalidad y programa ideal. Te contactaremos en 24–48 horas hábiles.</p>
        <p data-lang="en">Complete the form and our team will contact you to confirm age, format, and ideal program within 24–48 business hours.</p>
        <a href="#" class="btn btn-primary btn-lg btn-full">
          <span data-lang="es">🎓 Completar formulario de inscripción</span>
          <span data-lang="en">🎓 Complete enrollment form</span>
        </a>
        <p class="registro-note" data-lang="es">Tus datos se usan solo para contactarte sobre el Campamento de Verano.</p>
        <p class="registro-note" data-lang="en">Your data is used only to contact you about Summer Camp.</p>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>

<style>
  :root { --navy:#1A2156;--blue:#258EB6;--light-blue:#88D7F7;--white:#fff;--text:#374151;--border:rgba(26,33,86,.1);--card-bg:#f8fafc;--radius:12px;--radius-lg:20px;--shadow:0 4px 20px rgba(26,33,86,.08);--transition:.3s ease;--font-display:'Orbitron',sans-serif; }
  #hero { position:relative;min-height:90vh;display:flex;align-items:center;overflow:hidden; }
  .hero-bg { position:absolute;inset:0; }
  .hero-bg img { width:100%;height:100%;object-fit:cover; }
  .hero-overlay { position:absolute;inset:0;background:linear-gradient(135deg,rgba(10,14,56,.92) 0%,rgba(37,142,182,.30) 100%); }
  .hero-content { position:relative;z-index:2;padding:120px 0 80px;max-width:760px; }
  .pill { display:inline-block;border-radius:50px;padding:8px 20px;font-size:.8rem;font-weight:700;letter-spacing:1px;text-transform:uppercase;background:rgba(37,142,182,.25);border:1px solid rgba(136,215,247,.4);color:var(--light-blue); }
  .hero-eyebrow { margin-bottom:20px; }
  h1 { font-family:var(--font-display);font-size:clamp(2rem,5vw,3.2rem);font-weight:900;color:var(--white);line-height:1.2;margin-bottom:20px; }
  h1 em { color:var(--light-blue);font-style:normal; }
  .hero-sub { color:rgba(255,255,255,.78);font-size:1.05rem;max-width:620px;margin-bottom:28px;line-height:1.7; }
  .hero-pills { display:flex;flex-wrap:wrap;gap:12px;margin-bottom:32px; }
  .hero-feature { display:flex;align-items:center;gap:10px;background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.15);border-radius:50px;padding:8px 16px;color:var(--white);font-size:.82rem; }
  .hf-icon { font-size:1.1rem; }
  .hero-actions { display:flex;gap:14px;flex-wrap:wrap;margin-bottom:20px; }
  .hero-micro { color:rgba(255,255,255,.45);font-size:.78rem; }
  .highlight-bar { background:linear-gradient(90deg,var(--navy),#1e2d6e);padding:20px 0;border-bottom:1px solid rgba(136,215,247,.15); }
  .highlight-bar p { color:rgba(255,255,255,.8);font-size:.9rem;margin:0;text-align:center; }
  .highlight-bar strong { color:var(--light-blue); }
  .section { padding:88px 0; }
  .section-white { background:var(--white); }
  .section-light { background:#f0f4f8; }
  .section-navy { background:linear-gradient(135deg,#0a0e2e,var(--navy)); }
  .section-cta { background:linear-gradient(135deg,var(--navy),#258EB6); }
  .section-tag { display:inline-block;background:rgba(37,142,182,.12);color:var(--blue);border:1px solid rgba(37,142,182,.3);border-radius:50px;padding:6px 18px;font-size:.75rem;font-weight:700;letter-spacing:2px;text-transform:uppercase;margin-bottom:16px; }
  .section-tag-light { background:rgba(136,215,247,.15);color:var(--light-blue);border-color:rgba(136,215,247,.3); }
  .section-title { font-family:var(--font-display);color:var(--navy);font-size:clamp(1.6rem,3.5vw,2.4rem);font-weight:900;margin-bottom:16px;line-height:1.2; }
  .section-title-light { color:var(--white); }
  .section-subtitle { color:#6b7280;font-size:1rem;max-width:680px;margin:0 auto 48px;line-height:1.7; }
  .text-center { text-align:center; }
  .btn { display:inline-flex;align-items:center;gap:8px;padding:14px 28px;border-radius:50px;font-weight:700;font-size:.9rem;cursor:pointer;transition:var(--transition);border:2px solid transparent;text-decoration:none;white-space:nowrap; }
  .btn-primary { background:linear-gradient(135deg,var(--blue),#1a6f95);color:var(--white);border-color:var(--blue);box-shadow:0 4px 20px rgba(37,142,182,.4); }
  .btn-primary:hover { transform:translateY(-2px);box-shadow:0 8px 28px rgba(37,142,182,.55); }
  .btn-outline-white { background:transparent;color:var(--white);border-color:rgba(255,255,255,.5); }
  .btn-outline-white:hover { background:rgba(255,255,255,.1);border-color:var(--white); }
  .btn-lg { padding:18px 40px;font-size:1rem; }
  .btn-full { width:100%;justify-content:center; }
  .activities-grid { display:grid;grid-template-columns:repeat(3,1fr);gap:20px;margin-top:40px; }
  .act-card { background:var(--card-bg);border-radius:var(--radius-lg);padding:28px 20px;border:1px solid var(--border); }
  .act-icon { font-size:2.2rem;margin-bottom:12px; }
  .act-card h4 { color:var(--navy);font-size:.95rem;margin-bottom:8px; }
  .act-card p { color:#6b7280;font-size:.85rem;line-height:1.6;margin:0; }
  .rutas-grid { display:grid;grid-template-columns:repeat(3,1fr);gap:24px;margin-top:48px; }
  .ruta-card { background:var(--white);border-radius:var(--radius-lg);padding:32px 24px;box-shadow:var(--shadow);border:2px solid var(--border);position:relative; }
  .ruta-card-featured { border-color:var(--blue);box-shadow:0 8px 32px rgba(37,142,182,.2); }
  .ruta-popular { position:absolute;top:-14px;left:50%;transform:translateX(-50%);background:var(--blue);color:var(--white);border-radius:50px;padding:4px 18px;font-size:.72rem;font-weight:700;white-space:nowrap; }
  .ruta-age { font-family:var(--font-display);font-size:1.2rem;font-weight:900;color:var(--navy);margin-bottom:16px;line-height:1.3; }
  .ruta-age small { font-size:.75rem;color:var(--blue);font-family:'Montserrat',sans-serif;font-weight:700;display:block;margin-top:4px;text-transform:uppercase;letter-spacing:1px; }
  .ruta-card p { font-size:.88rem;color:#6b7280;line-height:1.6; }
  .benefits-grid { display:grid;grid-template-columns:1fr 1fr;gap:24px;margin-top:48px; }
  .benefit-item { display:flex;gap:16px;align-items:flex-start;padding:24px;background:rgba(255,255,255,.07);border-radius:var(--radius);border:1px solid rgba(136,215,247,.15); }
  .benefit-icon { font-size:2rem;flex-shrink:0; }
  .benefit-item h4 { color:var(--white);font-size:.95rem;margin-bottom:6px; }
  .benefit-item p { color:rgba(255,255,255,.65);font-size:.85rem;line-height:1.6;margin:0; }
  .photos-grid { display:grid;grid-template-columns:repeat(3,1fr);gap:16px; }
  .photos-grid img { width:100%;aspect-ratio:4/3;object-fit:cover;border-radius:var(--radius-lg); }
  .testimonials-grid { display:grid;grid-template-columns:repeat(3,1fr);gap:24px;margin-top:40px; }
  .test-card { background:var(--white);border-radius:var(--radius-lg);padding:28px;border:1px solid var(--border);box-shadow:var(--shadow); }
  .test-stars { color:#f59e0b;font-size:1.1rem;margin-bottom:12px; }
  .test-card p { font-size:.9rem;line-height:1.7;color:#374151;font-style:italic;margin-bottom:16px; }
  .test-card footer { font-size:.82rem;color:#6b7280; }
