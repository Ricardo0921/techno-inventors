---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---

<BaseLayout
  title="Desarrollo Profesional | Techno Inventors Puerto Rico"
  description="Certificaciones profesionales en Robótica, Drones FAA-107, Impresión 3D, Videojuegos VR e IA para adultos, educadores y empresas en Puerto Rico. Modelo Train-the-Trainer."
  ogTitle="Capacitación Profesional | Techno Inventors"
  ogDescription="Certifícate en tecnología de vanguardia: Robótica Educativa, Drones Comerciales FAA-107, Impresión 3D, VR y Robótica Industrial. Programas para empresas y educadores en Puerto Rico."
>
  <Header activePage="offerings" />

  <!-- ===== HERO ===== -->
  <section id="dp-hero">
    <div class="dp-hero-bg" aria-hidden="true">
      <div class="dp-glow g1"></div>
      <div class="dp-glow g2"></div>
    </div>
    <div class="container">
      <div class="dp-hero-inner">
        <div class="dp-hero-text">
          <div class="breadcrumb">
            <a href="/">Techno Inventors</a>
            <span>/</span>
            <a href="/#offerings" data-lang="es">Ofrecimientos</a>
            <a href="/#offerings" data-lang="en">Programs</a>
            <span>/</span>
            <span data-lang="es">Desarrollo Profesional</span>
            <span data-lang="en">Professional Development</span>
          </div>
          <div class="dp-badge-row">
            <span class="dp-badge">💼 <span data-lang="es">Adultos &amp; Empresas</span><span data-lang="en">Adults &amp; Business</span></span>
            <span class="dp-badge">🏆 <span data-lang="es">5 Certificaciones</span><span data-lang="en">5 Certifications</span></span>
            <span class="dp-badge">🌐 <span data-lang="es">Train-the-Trainer</span><span data-lang="en">Train-the-Trainer</span></span>
          </div>
          <h1 class="dp-title">
            <span data-lang="es">Capacitación Profesional en <em>Tecnología de Vanguardia</em></span>
            <span data-lang="en">Professional Training in <em>Cutting-Edge Technology</em></span>
          </h1>
          <p class="dp-desc">
            <span data-lang="es">Certifícate en las tecnologías más demandadas del mercado. Programas diseñados para educadores, profesionales independientes y empresas que quieren mantenerse a la vanguardia de la innovación en Puerto Rico y el mundo.</span>
            <span data-lang="en">Get certified in the most in-demand technologies on the market. Programs designed for educators, independent professionals, and companies that want to stay at the forefront of innovation in Puerto Rico and beyond.</span>
          </p>
          <div class="dp-hero-actions">
            <a href="#certifications" class="btn btn-cta">
              <span data-lang="es">🎓 Ver Certificaciones</span>
              <span data-lang="en">🎓 See Certifications</span>
            </a>
            <a href="/#contact-cta" class="btn btn-outline-light">
              <span data-lang="es">Solicitar Información →</span>
              <span data-lang="en">Request Information →</span>
            </a>
          </div>
        </div>
        <div class="dp-hero-gallery">
          <div class="dp-img-grid">
            <img src="/images/desarrollo-profesional/IMG_0925.webp" alt="Capacitación profesional robótica" loading="eager" class="dp-img-main" />
            <img src="/images/desarrollo-profesional/IMG_0928.webp" alt="Formación profesional tecnología" loading="eager" class="dp-img-sm" />
            <img src="/images/desarrollo-profesional/IMG_0937.webp" alt="Certificación robótica industrial" loading="eager" class="dp-img-sm" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== VALUE STRIP ===== -->
  <div id="dp-value-strip">
    <div class="container">
      <div class="dp-values">
        <div class="dp-value">
          <span class="dp-value-icon">⚡</span>
          <div>
            <strong data-lang="es">Certificaciones Reconocidas</strong>
            <strong data-lang="en">Recognized Certifications</strong>
            <span data-lang="es">Avaladas por instituciones líderes</span>
            <span data-lang="en">Backed by leading institutions</span>
          </div>
        </div>
        <div class="dp-value-divider"></div>
        <div class="dp-value">
          <span class="dp-value-icon">🤝</span>
          <div>
            <strong data-lang="es">Modelo Train-the-Trainer</strong>
            <strong data-lang="en">Train-the-Trainer Model</strong>
            <span data-lang="es">Forma a los formadores de tu empresa</span>
            <span data-lang="en">Train the trainers within your organization</span>
          </div>
        </div>
        <div class="dp-value-divider"></div>
        <div class="dp-value">
          <span class="dp-value-icon">🏭</span>
          <div>
            <strong data-lang="es">Para Empresas e Instituciones</strong>
            <strong data-lang="en">For Companies &amp; Institutions</strong>
            <span data-lang="es">Programas in-house y presenciales</span>
            <span data-lang="en">In-house and on-site programs</span>
          </div>
        </div>
        <div class="dp-value-divider"></div>
        <div class="dp-value">
          <span class="dp-value-icon">🇵🇷</span>
          <div>
            <strong data-lang="es">+5 Años de Experiencia</strong>
            <strong data-lang="en">5+ Years of Experience</strong>
            <span data-lang="es">Referentes en PR e internacionalmente</span>
            <span data-lang="en">Leaders in PR and internationally</span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- ===== CERTIFICATIONS ===== -->
  <section id="certifications" class="dp-section">
    <div class="container">
      <div class="text-center dp-section-head">
        <span class="section-tag" data-lang="es">Nuestras Certificaciones</span>
        <span class="section-tag" data-lang="en">Our Certifications</span>
        <h2 class="section-title" data-lang="es">5 Programas de Certificación Profesional</h2>
        <h2 class="section-title" data-lang="en">5 Professional Certification Programs</h2>
        <p class="section-subtitle" data-lang="es">Cada programa está diseñado para profesionales que buscan dominar tecnologías emergentes y llevar esas habilidades a sus organizaciones y comunidades.</p>
        <p class="section-subtitle" data-lang="en">Each program is designed for professionals who want to master emerging technologies and bring those skills to their organizations and communities.</p>
      </div>

      <div class="certs-grid">

        <!-- CERT 1: ROBÓTICA EDUCATIVA -->
        <div class="cert-card reveal">
          <div class="cert-img">
            <img src="/images/desarrollo-profesional/IMG_0954.webp" alt="Robótica Educativa" loading="lazy" />
            <div class="cert-number">01</div>
          </div>
          <div class="cert-body">
            <div class="cert-icon-wrap">🤖</div>
            <h3 data-lang="es">Robótica Educativa</h3>
            <h3 data-lang="en">Educational Robotics</h3>
            <p data-lang="es">Aprende a integrar la robótica en entornos educativos. Desde programación básica hasta automatización avanzada. Ideal para maestros, coordinadores STEM y profesionales del sector educativo.</p>
            <p data-lang="en">Learn to integrate robotics into educational environments. From basic programming to advanced automation. Ideal for teachers, STEM coordinators, and education sector professionals.</p>
            <ul class="cert-highlights">
              <li data-lang="es">✓ Diseño de proyectos de robótica pedagógica</li>
              <li data-lang="en">✓ Design of pedagogical robotics projects</li>
              <li data-lang="es">✓ Programación visual y orientada a objetos</li>
              <li data-lang="en">✓ Visual and object-oriented programming</li>
              <li data-lang="es">✓ Implementación en aula y talleres</li>
              <li data-lang="en">✓ Classroom and workshop implementation</li>
              <li data-lang="es">✓ Certificación oficial al completar</li>
              <li data-lang="en">✓ Official certification upon completion</li>
            </ul>
            <div class="cert-footer">
              <span class="cert-meta" data-lang="es">👩‍🏫 Educadores · Maestros · STEM Coordinators</span>
              <span class="cert-meta" data-lang="en">👩‍🏫 Educators · Teachers · STEM Coordinators</span>
              <a href="/#contact-cta" class="btn btn-primary">
                <span data-lang="es">Solicitar Info</span>
                <span data-lang="en">Request Info</span>
              </a>
            </div>
          </div>
        </div>

        <!-- CERT 2: VIDEOJUEGOS VR -->
        <div class="cert-card reveal reveal-delay-1">
          <div class="cert-img">
            <img src="/images/desarrollo-profesional/IMG_0928.webp" alt="Videojuegos y Realidad Virtual" loading="lazy" />
            <div class="cert-number">02</div>
          </div>
          <div class="cert-body">
            <div class="cert-icon-wrap">🎮</div>
            <h3 data-lang="es">Videojuegos &amp; Realidad Virtual</h3>
            <h3 data-lang="en">Video Games &amp; Virtual Reality</h3>
            <p data-lang="es">Domina las herramientas del desarrollo de videojuegos y experiencias de realidad virtual. Aprende a crear entornos inmersivos para educación, entretenimiento y simulación empresarial.</p>
            <p data-lang="en">Master the tools of video game development and virtual reality experiences. Learn to create immersive environments for education, entertainment, and business simulation.</p>
            <ul class="cert-highlights">
              <li data-lang="es">✓ Desarrollo con motores de juego (Unity/Unreal)</li>
              <li data-lang="en">✓ Development with game engines (Unity/Unreal)</li>
              <li data-lang="es">✓ Diseño de experiencias VR e inmersivas</li>
              <li data-lang="en">✓ VR and immersive experience design</li>
              <li data-lang="es">✓ Narrativa digital y game design</li>
              <li data-lang="en">✓ Digital storytelling and game design</li>
              <li data-lang="es">✓ Aplicaciones educativas y empresariales</li>
              <li data-lang="en">✓ Educational and business applications</li>
            </ul>
            <div class="cert-footer">
              <span class="cert-meta" data-lang="es">🎯 Desarrolladores · Diseñadores · Creativos</span>
              <span class="cert-meta" data-lang="en">🎯 Developers · Designers · Creatives</span>
              <a href="/#contact-cta" class="btn btn-primary">
                <span data-lang="es">Solicitar Info</span>
                <span data-lang="en">Request Info</span>
              </a>
            </div>
          </div>
        </div>

        <!-- CERT 3: ROBÓTICA INDUSTRIAL -->
        <div class="cert-card reveal reveal-delay-2">
          <div class="cert-img">
            <img src="/images/desarrollo-profesional/IMG_0937.webp" alt="Robótica Industrial" loading="lazy" />
            <div class="cert-number">03</div>
          </div>
          <div class="cert-body">
            <div class="cert-icon-wrap">🏭</div>
            <h3 data-lang="es">Robótica Industrial</h3>
            <h3 data-lang="en">Industrial Robotics</h3>
            <p data-lang="es">Capacitación avanzada en sistemas robóticos para entornos industriales y manufactura. Aprende a programar, operar y mantener robots industriales para optimizar procesos productivos.</p>
            <p data-lang="en">Advanced training in robotic systems for industrial and manufacturing environments. Learn to program, operate, and maintain industrial robots to optimize production processes.</p>
            <ul class="cert-highlights">
              <li data-lang="es">✓ Programación de brazos robóticos</li>
              <li data-lang="en">✓ Robotic arm programming</li>
              <li data-lang="es">✓ Automatización y control de procesos</li>
              <li data-lang="en">✓ Process automation and control</li>
              <li data-lang="es">✓ Integración con sistemas IoT</li>
              <li data-lang="en">✓ IoT systems integration</li>
              <li data-lang="es">✓ Seguridad industrial y mantenimiento</li>
              <li data-lang="en">✓ Industrial safety and maintenance</li>
            </ul>
            <div class="cert-footer">
              <span class="cert-meta" data-lang="es">🔧 Ingenieros · Técnicos · Gerentes de Planta</span>
              <span class="cert-meta" data-lang="en">🔧 Engineers · Technicians · Plant Managers</span>
              <a href="/#contact-cta" class="btn btn-primary">
                <span data-lang="es">Solicitar Info</span>
                <span data-lang="en">Request Info</span>
              </a>
            </div>
          </div>
        </div>

        <!-- CERT 4: DRONES COMERCIALES FAA-107 -->
        <div class="cert-card cert-featured reveal">
          <div class="cert-img">
            <img src="/images/desarrollo-profesional/IMG_0962.webp" alt="Drones Comerciales FAA-107" loading="lazy" />
            <div class="cert-number">04</div>
            <span class="cert-badge-tag" data-lang="es">⭐ Certificación FAA</span>
            <span class="cert-badge-tag" data-lang="en">⭐ FAA Certification</span>
          </div>
          <div class="cert-body">
            <div class="cert-icon-wrap cert-icon-featured">✈️</div>
            <h3 data-lang="es">Drones Comerciales — Licencia FAA Part 107</h3>
            <h3 data-lang="en">Commercial Drones — FAA Part 107 License</h3>
            <p data-lang="es">Prepárate para obtener tu licencia de piloto de drones comerciales bajo la regulación FAA Part 107. Aprende a operar drones para fotografía aérea, inspecciones, cartografía y más en entornos comerciales y profesionales.</p>
            <p data-lang="en">Prepare to earn your commercial drone pilot license under FAA Part 107 regulation. Learn to operate drones for aerial photography, inspections, mapping, and more in commercial and professional environments.</p>
            <ul class="cert-highlights">
              <li data-lang="es">✓ Regulaciones FAA Part 107 completas</li>
              <li data-lang="en">✓ Complete FAA Part 107 regulations</li>
              <li data-lang="es">✓ Operaciones de vuelo seguro y planificación</li>
              <li data-lang="en">✓ Safe flight operations and planning</li>
              <li data-lang="es">✓ Meteorología y espacio aéreo</li>
              <li data-lang="en">✓ Meteorology and airspace regulations</li>
              <li data-lang="es">✓ Aplicaciones: inspección, fotografía, mapeo</li>
              <li data-lang="en">✓ Applications: inspection, photography, mapping</li>
              <li data-lang="es">✓ Preparación para el examen oficial FAA</li>
              <li data-lang="en">✓ Preparation for the official FAA exam</li>
            </ul>
            <div class="cert-footer">
              <span class="cert-meta" data-lang="es">🚁 Profesionales · Fotógrafos · Ingenieros · Constructoras</span>
              <span class="cert-meta" data-lang="en">🚁 Professionals · Photographers · Engineers · Construction</span>
              <a href="/#contact-cta" class="btn btn-cta">
                <span data-lang="es">Solicitar Info</span>
                <span data-lang="en">Request Info</span>
              </a>
            </div>
          </div>
        </div>

        <!-- CERT 5: MÁQUINAS 3D / IMPRESIÓN 3D -->
        <div class="cert-card reveal reveal-delay-1">
          <div class="cert-img">
            <img src="/images/desarrollo-profesional/IMG_0925.webp" alt="Impresión 3D y Fabricación Digital" loading="lazy" />
            <div class="cert-number">05</div>
          </div>
          <div class="cert-body">
            <div class="cert-icon-wrap">🖨️</div>
            <h3 data-lang="es">Máquinas 3D — Impresión &amp; Fabricación Digital</h3>
            <h3 data-lang="en">3D Machines — Printing &amp; Digital Fabrication</h3>
            <p data-lang="es">Domina el mundo de la fabricación digital con impresoras 3D. Desde el modelado CAD hasta la producción de prototipos y piezas funcionales. Aplicaciones en manufactura, diseño industrial, medicina y educación.</p>
            <p data-lang="en">Master the world of digital manufacturing with 3D printers. From CAD modeling to producing prototypes and functional parts. Applications in manufacturing, industrial design, medicine, and education.</p>
            <ul class="cert-highlights">
              <li data-lang="es">✓ Modelado 3D y diseño CAD</li>
              <li data-lang="en">✓ 3D modeling and CAD design</li>
              <li data-lang="es">✓ Configuración y operación de impresoras 3D</li>
              <li data-lang="en">✓ 3D printer setup and operation</li>
              <li data-lang="es">✓ Materiales y técnicas de impresión</li>
              <li data-lang="en">✓ Materials and printing techniques</li>
              <li data-lang="es">✓ Prototipado rápido para industria</li>
              <li data-lang="en">✓ Rapid prototyping for industry</li>
            </ul>
            <div class="cert-footer">
              <span class="cert-meta" data-lang="es">🔩 Diseñadores · Ingenieros · Emprendedores · Fabricantes</span>
              <span class="cert-meta" data-lang="en">🔩 Designers · Engineers · Entrepreneurs · Manufacturers</span>
              <a href="/#contact-cta" class="btn btn-primary">
                <span data-lang="es">Solicitar Info</span>
                <span data-lang="en">Request Info</span>
              </a>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ===== TRAIN THE TRAINER ===== -->
  <section id="train-trainer" class="dp-section dp-section-dark">
    <div class="container">
      <div class="ttt-grid">
        <div class="ttt-img reveal">
          <img src="/images/desarrollo-profesional/IMG_0962.webp" alt="Train the Trainer Techno Inventors" loading="lazy" />
        </div>
        <div class="ttt-text reveal">
          <span class="section-tag section-tag-light" data-lang="es">Modelo Empresarial</span>
          <span class="section-tag section-tag-light" data-lang="en">Business Model</span>
          <h2 class="section-title section-title-light" data-lang="es">Train-the-Trainer: Lleva la Innovación a Tu Empresa</h2>
          <h2 class="section-title section-title-light" data-lang="en">Train-the-Trainer: Bring Innovation to Your Company</h2>
          <p data-lang="es">Nuestro modelo Train-the-Trainer está diseñado para que empresas, escuelas e instituciones puedan formar a sus propios instructores certificados. Escalamos la innovación desde adentro.</p>
          <p data-lang="en">Our Train-the-Trainer model is designed so that companies, schools, and institutions can train their own certified instructors. We scale innovation from within.</p>
          <div class="ttt-benefits">
            <div class="ttt-benefit">
              <span class="ttt-icon">🏢</span>
              <div>
                <strong data-lang="es">Programas In-House</strong>
                <strong data-lang="en">In-House Programs</strong>
                <span data-lang="es">Capacitamos directamente en tus instalaciones</span>
                <span data-lang="en">We train directly at your facilities</span>
              </div>
            </div>
            <div class="ttt-benefit">
              <span class="ttt-icon">📈</span>
              <div>
                <strong data-lang="es">ROI Medible</strong>
                <strong data-lang="en">Measurable ROI</strong>
                <span data-lang="es">Impacto directo en productividad y cultura de innovación</span>
                <span data-lang="en">Direct impact on productivity and innovation culture</span>
              </div>
            </div>
            <div class="ttt-benefit">
              <span class="ttt-icon">🎯</span>
              <div>
                <strong data-lang="es">Currículo a la Medida</strong>
                <strong data-lang="en">Custom Curriculum</strong>
                <span data-lang="es">Adaptamos el contenido a tu industria y necesidades</span>
                <span data-lang="en">We adapt content to your industry and needs</span>
              </div>
            </div>
            <div class="ttt-benefit">
              <span class="ttt-icon">🏆</span>
              <div>
                <strong data-lang="es">Certificación Institucional</strong>
                <strong data-lang="en">Institutional Certification</strong>
                <span data-lang="es">Tus instructores reciben credencial oficial de Techno Inventors</span>
                <span data-lang="en">Your instructors receive an official Techno Inventors credential</span>
              </div>
            </div>
          </div>
          <div style="margin-top: 32px; display: flex; gap: 14px; flex-wrap: wrap;">
            <a href="/#contact-cta" class="btn btn-cta">
              <span data-lang="es">🤝 Hablar con un Asesor</span>
              <span data-lang="en">🤝 Speak with an Advisor</span>
            </a>
            <a href="mailto:info@technoinventors.com?subject=Programa%20Train-the-Trainer" class="btn btn-outline">
              <span data-lang="es">📧 info@technoinventors.com</span>
              <span data-lang="en">📧 info@technoinventors.com</span>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== WHO IS IT FOR ===== -->
  <section id="dp-audience" class="dp-section">
    <div class="container">
      <div class="text-center dp-section-head">
        <span class="section-tag" data-lang="es">¿Para quién es?</span>
        <span class="section-tag" data-lang="en">Who is it for?</span>
        <h2 class="section-title" data-lang="es">Profesionales que Transforman su Futuro</h2>
        <h2 class="section-title" data-lang="en">Professionals Transforming Their Future</h2>
      </div>
      <div class="audience-grid">
        <div class="audience-card reveal">
          <div class="audience-icon">👩‍🏫</div>
          <h4 data-lang="es">Educadores &amp; Maestros</h4>
          <h4 data-lang="en">Educators &amp; Teachers</h4>
          <p data-lang="es">Integra tecnología de vanguardia en el aula y certifícate como instructor STEM.</p>
          <p data-lang="en">Integrate cutting-edge technology in the classroom and certify as a STEM instructor.</p>
        </div>
        <div class="audience-card reveal reveal-delay-1">
          <div class="audience-icon">🏭</div>
          <h4 data-lang="es">Empresas &amp; Manufactura</h4>
          <h4 data-lang="en">Companies &amp; Manufacturing</h4>
          <p data-lang="es">Automatiza procesos, certifica a tu equipo técnico y lidera la transformación digital.</p>
          <p data-lang="en">Automate processes, certify your technical team, and lead digital transformation.</p>
        </div>
        <div class="audience-card reveal reveal-delay-2">
          <div class="audience-icon">🚁</div>
          <h4 data-lang="es">Fotógrafos &amp; Creativos</h4>
          <h4 data-lang="en">Photographers &amp; Creatives</h4>
          <p data-lang="es">Obtén tu licencia FAA-107 y expande tus servicios con fotografía y video aéreo profesional.</p>
          <p data-lang="en">Get your FAA-107 license and expand your services with professional aerial photography and video.</p>
        </div>
        <div class="audience-card reveal">
          <div class="audience-icon">🔧</div>
          <h4 data-lang="es">Ingenieros &amp; Técnicos</h4>
          <h4 data-lang="en">Engineers &amp; Technicians</h4>
          <p data-lang="es">Actualiza tus conocimientos en robótica industrial, impresión 3D y sistemas automatizados.</p>
          <p data-lang="en">Update your knowledge in industrial robotics, 3D printing, and automated systems.</p>
        </div>
        <div class="audience-card reveal reveal-delay-1">
          <div class="audience-icon">🏛️</div>
          <h4 data-lang="es">Instituciones &amp; Gobierno</h4>
          <h4 data-lang="en">Institutions &amp; Government</h4>
          <p data-lang="es">Desarrolla programas de capacitación masiva para comunidades y sectores prioritarios.</p>
          <p data-lang="en">Develop mass training programs for communities and priority sectors.</p>
        </div>
        <div class="audience-card reveal reveal-delay-2">
          <div class="audience-icon">🎮</div>
          <h4 data-lang="es">Emprendedores &amp; Startups</h4>
          <h4 data-lang="en">Entrepreneurs &amp; Startups</h4>
          <p data-lang="es">Adquiere las habilidades técnicas para lanzar productos innovadores en tecnología y hardware.</p>
          <p data-lang="en">Acquire the technical skills to launch innovative products in technology and hardware.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== CTA ===== -->
  <section id="dp-cta">
    <div class="dp-cta-bg" aria-hidden="true"></div>
    <div class="container">
      <div class="dp-cta-inner reveal">
        <h2 data-lang="es">¿Listo para certificarte?</h2>
