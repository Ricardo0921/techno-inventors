---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="Techno Inventors | eSTREAM Education Puerto Rico"
  description="Techno Inventors forma líderes socialmente responsables a través del modelo eSTREAM (eSports, Ciencia, Tecnología, Robótica, Ingeniería, Arte y Matemáticas) en Puerto Rico."
>
  <Header />

  <!-- ===== LIGHTBOX ===== -->
  <div id="lightbox" role="dialog" aria-modal="true">
    <button id="lightbox-close" aria-label="Close">&times;</button>
    <img id="lightbox-img" src="" alt="" />
  </div>

  <!-- ===== HERO ===== -->
  <section id="hero" aria-label="Hero">
    <div class="hero-bg-canvas" aria-hidden="true">
      <div class="hero-particles" id="hero-particles"></div>
      <div class="hero-glow" style="width:700px;height:700px;top:-200px;right:-200px;"></div>
      <div class="hero-glow" style="width:400px;height:400px;bottom:-100px;left:-100px;opacity:0.5;"></div>
    </div>
    <div class="container">
      <div class="hero-content">
        <div class="hero-text">
          <div class="badge"><span class="badge-dot"></span>eSTREAM Education · Puerto Rico</div>
          <h1 class="hero-title">
            <span data-lang="es">Formamos los <span class="accent">Líderes del Futuro</span> Tecnológico</span>
            <span data-lang="en">We Build the <span class="accent">Future's Tech Leaders</span></span>
          </h1>
          <p class="hero-desc">
            <span data-lang="es">Techno Inventors es una organización sin fines de lucro que educa a niños y jóvenes de Puerto Rico en eSports, Ciencias, Tecnología, Robótica, Ingeniería, Arte y Matemáticas — el modelo <strong style="color:var(--light-blue);">eSTREAM</strong>.</span>
            <span data-lang="en">Techno Inventors is a nonprofit that educates children and youth in Puerto Rico through eSports, Science, Technology, Robotics, Engineering, Arts and Mathematics — the <strong style="color:var(--light-blue);">eSTREAM</strong> model.</span>
          </p>
          <div class="hero-buttons">
            <a href="#offerings" class="btn btn-primary">
              <span data-lang="es">🚀 Ver Ofrecimientos</span>
              <span data-lang="en">🚀 Explore Programs</span>
            </a>
            <a href="#contact-cta" class="btn btn-outline">
              <span data-lang="es">Hablar con un Asesor</span>
              <span data-lang="en">Speak with an Advisor</span>
            </a>
          </div>
          <div class="hero-stats">
            <div class="hero-stat">
              <span class="num" data-count="35753">0</span>
              <span class="lbl" data-lang="es">Participantes</span>
              <span class="lbl" data-lang="en">Participants</span>
            </div>
            <div class="hero-stat">
              <span class="num" data-count="8894">0</span>
              <span class="lbl" data-lang="es">Hrs de Voluntariado</span>
              <span class="lbl" data-lang="en">Volunteer Hours</span>
            </div>
            <div class="hero-stat">
              <span class="num" data-count="73">0</span>
              <span class="lbl" data-lang="es">Organizaciones</span>
              <span class="lbl" data-lang="en">Organizations</span>
            </div>
          </div>
        </div>
        <div class="hero-visual">
          <div class="hero-img-wrap">
            <img src="/images/Ofrecimientos/After-School.webp" alt="Students learning STEM at Techno Inventors" loading="eager" />
          </div>
          <div class="hero-float-badge b1">
            <span class="icon">🤖</span>
            <div>
              <strong style="display:block;color:white;font-size:0.85rem;">Robótica &amp; Coding</strong>
              <span style="color:rgba(255,255,255,0.6);font-size:0.72rem;" data-lang="es">Aprende haciendo</span>
              <span style="color:rgba(255,255,255,0.6);font-size:0.72rem;" data-lang="en">Learn by doing</span>
            </div>
          </div>
          <div class="hero-float-badge b2">
            <span class="icon">🏆</span>
            <div>
              <strong style="display:block;color:white;font-size:0.85rem;" data-lang="es">Competencias Mundiales</strong>
              <strong style="display:block;color:white;font-size:0.85rem;" data-lang="en">World Competitions</strong>
              <span style="color:rgba(255,255,255,0.6);font-size:0.72rem;" data-lang="es">Representando a PR</span>
              <span style="color:rgba(255,255,255,0.6);font-size:0.72rem;" data-lang="en">Representing PR</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== eSTREAM BAR ===== -->
  <div id="estream-bar" aria-label="eSTREAM model">
    <div class="estream-inner">
      <div class="estream-item"><span class="estream-letter">e</span><span class="estream-word">eSports</span></div>
      <div class="estream-item"><span class="estream-letter">S</span><span class="estream-word" data-lang="es">Ciencias</span><span class="estream-word" data-lang="en">Science</span></div>
      <div class="estream-item"><span class="estream-letter">T</span><span class="estream-word" data-lang="es">Tecnología</span><span class="estream-word" data-lang="en">Technology</span></div>
      <div class="estream-item"><span class="estream-letter">R</span><span class="estream-word" data-lang="es">Robótica</span><span class="estream-word" data-lang="en">Robotics</span></div>
      <div class="estream-item"><span class="estream-letter">E</span><span class="estream-word" data-lang="es">Ingeniería</span><span class="estream-word" data-lang="en">Engineering</span></div>
      <div class="estream-item"><span class="estream-letter">A</span><span class="estream-word" data-lang="es">Arte</span><span class="estream-word" data-lang="en">Arts</span></div>
      <div class="estream-item"><span class="estream-letter">M</span><span class="estream-word" data-lang="es">Matemáticas</span><span class="estream-word" data-lang="en">Mathematics</span></div>
    </div>
  </div>

  <!-- ===== OPTIN / NEWSLETTER ===== -->
  <section id="optin-bar" aria-label="Suscripción">
    <div class="optin-bg-glow"></div>
    <div class="container optin-container">

      <!-- LEFT: headline -->
      <div class="optin-headline">
        <div class="optin-tag">
          <span class="optin-dot"></span>
          <span data-lang="es">¡Mantente informado!</span>
          <span data-lang="en">Stay informed!</span>
        </div>
        <h2 class="optin-title">
          <span data-lang="es">Únete a la comunidad <em>Techno Inventors</em></span>
          <span data-lang="en">Join the <em>Techno Inventors</em> community</span>
        </h2>
        <p class="optin-sub" data-lang="es">Recibe noticias, fechas de inscripción y recursos eSTREAM directo en tu correo y teléfono.</p>
        <p class="optin-sub" data-lang="en">Get news, enrollment dates, and eSTREAM resources directly to your email and phone.</p>
        <div class="optin-badges">
          <span class="optin-badge">🔒 <span data-lang="es">100% privado</span><span data-lang="en">100% private</span></span>
          <span class="optin-badge">📵 <span data-lang="es">Sin spam</span><span data-lang="en">No spam</span></span>
          <span class="optin-badge">✅ <span data-lang="es">Cancela cuando quieras</span><span data-lang="en">Cancel anytime</span></span>
        </div>
      </div>

      <!-- RIGHT: form -->
      <div class="optin-form-wrap">
        <form
          class="optin-form"
          action="https://mailwizz.technoinventors.com/index.php/lists/ps633g07plca6/subscribe"
          method="post"
        >
          <div class="optin-fields">
            <div class="optin-field">
              <label data-lang="es">Nombre</label>
              <label data-lang="en">Name</label>
              <input type="text" name="FNAME" placeholder="Tu nombre" required autocomplete="given-name" />
            </div>
            <div class="optin-field">
              <label>Email</label>
              <input type="email" name="EMAIL" placeholder="tu@email.com" required autocomplete="email" />
            </div>
            <div class="optin-field">
              <label data-lang="es">Teléfono</label>
              <label data-lang="en">Phone</label>
              <input type="tel" name="PHONE_NUMBER" placeholder="+1 (787) 000-0000" autocomplete="tel" />
            </div>
          </div>
          <button type="submit" class="optin-btn">
            <span data-lang="es">🚀 ¡Suscribirme!</span>
            <span data-lang="en">🚀 Subscribe!</span>
          </button>
          <label class="optin-consent">
            <div class="optin-check-wrap">
              <input type="checkbox" name="sms_consent" required />
              <span class="optin-checkmark"></span>
            </div>
            <span class="optin-consent-text">
              <span data-lang="es">Acepto recibir mensajes SMS y correos electrónicos de Techno Inventors. La frecuencia varía. Pueden aplicarse tarifas de mensajes y datos. Responda <strong>STOP</strong> para darse de baja. <a href="/privacidad">Ver Política de Privacidad</a>.</span>
              <span data-lang="en">I agree to receive SMS messages and emails from Techno Inventors. Message frequency varies. Message and data rates may apply. Reply <strong>STOP</strong> to unsubscribe. <a href="/privacidad">View Privacy Policy</a>.</span>
            </span>
          </label>
        </form>
      </div>

    </div>
  </section>

  <!-- ===== ABOUT ===== -->
  <section id="about" class="section">
    <div class="container">
      <div class="about-grid">
        <div class="about-img-grid reveal">
          <img src="/images/early-inventors/IMG_0459.webp" alt="Early Inventors student learning" class="img-tall" style="height:100%;min-height:360px;" />
          <img src="/images/olimpiadas/IMG_5247.webp" alt="Olimpiadas de robótica" style="height:170px;" />
          <img src="/images/wro/IMG_1622.webp" alt="World Robot Olympiad Puerto Rico" style="height:170px;" />
        </div>
        <div class="about-text reveal reveal-delay-2">
          <span class="section-tag" data-lang="es">¿Quiénes Somos?</span>
          <span class="section-tag" data-lang="en">About Us</span>
          <h2 class="section-title" data-lang="es">La sinergia entre precisión técnica e impacto comunitario</h2>
          <h2 class="section-title" data-lang="en">The synergy between technical precision and community impact</h2>
          <p class="section-subtitle" data-lang="es">Somos una organización sin fines de lucro en Puerto Rico fundada por el Ing. César Cabrera. Capacitamos y promovemos líderes socialmente responsables que contribuyen a resolver problemas y al desarrollo de la comunidad a través del modelo educativo eSTREAM.</p>
          <p class="section-subtitle" data-lang="en">We are a nonprofit organization in Puerto Rico founded by Engineer César Cabrera. We train and promote socially responsible leaders who contribute to problem-solving and community development through the eSTREAM educational model.</p>
          <div class="about-features">
            <div class="about-feature">
              <span class="feature-icon">🎓</span>
              <div class="feature-text">
                <h4 data-lang="es">Educación por Proyectos</h4>
                <h4 data-lang="en">Project-Based Learning</h4>
                <p data-lang="es">Aprenden construyendo, programando y compitiendo en el mundo real.</p>
                <p data-lang="en">Students learn by building, coding and competing in the real world.</p>
              </div>
            </div>
            <div class="about-feature">
              <span class="feature-icon">🌐</span>
              <div class="feature-text">
                <h4 data-lang="es">Competencias Mundiales</h4>
                <h4 data-lang="en">World Competitions</h4>
                <p data-lang="es">Participamos en torneos y olimpiadas internacionales de tecnología.</p>
                <p data-lang="en">We participate in international technology tournaments and olympiads.</p>
              </div>
            </div>
            <div class="about-feature">
              <span class="feature-icon">🤝</span>
              <div class="feature-text">
                <h4 data-lang="es">Red de Alianzas</h4>
                <h4 data-lang="en">Alliance Network</h4>
                <p data-lang="es">Colaboramos con universidades, empresas y organizaciones líderes.</p>
                <p data-lang="en">We collaborate with leading universities, companies and organizations.</p>
              </div>
            </div>
            <div class="about-feature">
              <span class="feature-icon">💡</span>
              <div class="feature-text">
                <h4 data-lang="es">Innovación Social</h4>
                <h4 data-lang="en">Social Innovation</h4>
                <p data-lang="es">Transformamos comunidades a través de la tecnología y el liderazgo.</p>
                <p data-lang="en">We transform communities through technology and leadership.</p>
              </div>
            </div>
          </div>
          <div style="margin-top:28px;">
            <a href="/nosotros" class="btn btn-navy">
              <span data-lang="es">Conocer más →</span>
              <span data-lang="en">Learn more →</span>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== STATS ===== -->
  <section id="stats" aria-label="Impact statistics">
    <div class="container">
      <div class="stats-grid">
        <div class="stat-card reveal">
          <span class="stat-number" data-count="35753">35,753</span>
          <p class="stat-label" data-lang="es">Estudiantes Impactados</p>
          <p class="stat-label" data-lang="en">Students Impacted</p>
          <div class="stat-divider"></div>
        </div>
        <div class="stat-card reveal reveal-delay-1">
          <span class="stat-number" data-count="8894">8,894</span>
          <p class="stat-label" data-lang="es">Horas de Voluntariado</p>
          <p class="stat-label" data-lang="en">Volunteer Hours</p>
          <div class="stat-divider"></div>
        </div>
        <div class="stat-card reveal reveal-delay-2">
          <span class="stat-number" data-count="73">73</span>
          <p class="stat-label" data-lang="es">Instituciones Aliadas</p>
          <p class="stat-label" data-lang="en">Partner Institutions</p>
          <div class="stat-divider"></div>
        </div>
        <div class="stat-card reveal reveal-delay-3">
          <span class="stat-number" data-count="3456">3,456</span>
          <p class="stat-label" data-lang="es">Familias Beneficiadas</p>
          <p class="stat-label" data-lang="en">Families Benefited</p>
          <div class="stat-divider"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== OFFERINGS ===== -->
  <section id="offerings" class="section">
    <div class="container">
      <div class="text-center">
        <span class="section-tag" data-lang="es">Nuestros Programas</span>
        <span class="section-tag" data-lang="en">Our Programs</span>
        <h2 class="section-title" data-lang="es">Ofrecimientos para cada etapa del aprendizaje</h2>
        <h2 class="section-title" data-lang="en">Programs for every stage of learning</h2>
        <p class="section-subtitle" data-lang="es">Diseñamos experiencias educativas inmersivas que despiertan la pasión por la tecnología y desarrollan las habilidades del siglo XXI que el mundo necesita.</p>
        <p class="section-subtitle" data-lang="en">We design immersive educational experiences that ignite a passion for technology and develop the 21st-century skills the world needs.</p>
      </div>
      <div class="offerings-grid">

        <!-- ROW 1 -->
        <div class="offering-card reveal">
          <div class="offering-img">
            <img src="/images/Ofrecimientos/After-School.webp" alt="After School Program Techno Inventors" loading="lazy" />
            <span class="offering-tag" data-lang="es">Lun – Vie</span>
            <span class="offering-tag" data-lang="en">Mon – Fri</span>
          </div>
          <div class="offering-body">
            <h3 data-lang="es">After School</h3>
            <h3 data-lang="en">After School</h3>
            <p data-lang="es">Programa extracurricular de lunes a viernes. Ciencia, robótica y programación STEAM para niños y jóvenes con acompañamiento personalizado presencial o virtual.</p>
            <p data-lang="en">Weekday after-school program. Science, robotics, and STEAM programming for children and youth with in-person or virtual personalized mentoring.</p>
            <div class="offering-footer">
              <span class="offering-meta">📚 <span data-lang="es">6 – 18 años</span><span data-lang="en">Ages 6–18</span></span>
              <a href="/ofrecimientos/after-school" class="btn btn-primary">
                <span data-lang="es">Ver más</span><span data-lang="en">Learn more</span>
              </a>
            </div>
          </div>
        </div>

        <div class="offering-card reveal reveal-delay-1">
          <div class="offering-img">
            <img src="/images/Ofrecimientos/Saturday-Club.webp" alt="Saturday Tech Clubs" loading="lazy" />
            <span class="offering-tag" data-lang="es">Todos los Sábados</span>
            <span class="offering-tag" data-lang="en">Every Saturday</span>
          </div>
          <div class="offering-body">
            <h3 data-lang="es">Saturday Club</h3>
            <h3 data-lang="en">Saturday Club</h3>
            <p data-lang="es">Clubes sabatinos donde exploramos robótica, eSports, diseño digital y programación en un ambiente dinámico y colaborativo. ¡Los sábados son para innovar!</p>
            <p data-lang="en">Saturday clubs where we explore robotics, eSports, digital design, and programming in a dynamic and collaborative environment. Saturdays are for innovating!</p>
            <div class="offering-footer">
              <span class="offering-meta">📅 <span data-lang="es">Sábados</span><span data-lang="en">Saturdays</span></span>
              <a href="/ofrecimientos/saturday-club" class="btn btn-primary">
                <span data-lang="es">Ver más</span><span data-lang="en">Learn more</span>
              </a>
            </div>
          </div>
        </div>

        <div class="offering-card reveal reveal-delay-2">
          <div class="offering-img">
            <img src="/images/Ofrecimientos/Summer-Camp.webp" alt="Summer Tech Camp" loading="lazy" />
            <span class="offering-tag" data-lang="es">Verano</span>
            <span class="offering-tag" data-lang="en">Summer</span>
          </div>
          <div class="offering-body">
            <h3 data-lang="es">Summer Camp</h3>
            <h3 data-lang="en">Summer Camp</h3>
            <p data-lang="es">Campamento de verano con inmersión total en tecnología e innovación. Semanas intensivas de programación, robótica, drones, realidad virtual y diseño digital.</p>
            <p data-lang="en">Summer camp with total technology and innovation immersion. Intensive weeks of programming, robotics, drones, virtual reality, and digital design.</p>
            <div class="offering-footer">
              <span class="offering-meta">☀️ <span data-lang="es">Junio – Agosto</span><span data-lang="en">June – August</span></span>
              <a href="/ofrecimientos/summer-camp" class="btn btn-primary">
                <span data-lang="es">Ver más</span><span data-lang="en">Learn more</span>
              </a>
            </div>
          </div>
        </div>

        <!-- ROW 2 -->
        <div class="offering-card reveal">
          <div class="offering-img">
            <img src="/images/Ofrecimientos/Spring-Break-Camp.webp" alt="Spring Break Camp" loading="lazy" />
            <span class="offering-tag" data-lang="es">Semana Santa</span>
            <span class="offering-tag" data-lang="en">Spring Break</span>
          </div>
          <div class="offering-body">
            <h3 data-lang="es">Spring Break Camp</h3>
            <h3 data-lang="en">Spring Break Camp</h3>
            <p data-lang="es">Campamento intensivo durante las vacaciones de primavera. Una semana repleta de retos tecnológicos, proyectos de ingeniería y aventura digital.</p>
            <p data-lang="en">Intensive camp during spring break. A week packed with tech challenges, engineering projects, and digital adventure.</p>
            <div class="offering-footer">
              <span class="offering-meta">🌸 <span data-lang="es">Semana de Pascua</span><span data-lang="en">Easter Week</span></span>
              <a href="/ofrecimientos/spring-break-camp" class="btn btn-primary">
                <span data-lang="es">Ver más</span><span data-lang="en">Learn more</span>
              </a>
            </div>
          </div>
        </div>

        <div class="offering-card reveal reveal-delay-1">
          <div class="offering-img">
            <img src="/images/Ofrecimientos/Winter-Camp.webp" alt="Winter Tech Camp" loading="lazy" />
            <span class="offering-tag" data-lang="es">Navidades</span>
            <span class="offering-tag" data-lang="en">Winter Break</span>
          </div>
          <div class="offering-body">
            <h3 data-lang="es">Winter Camp</h3>
            <h3 data-lang="en">Winter Camp</h3>
            <p data-lang="es">¡El mejor regalo navideño! Campamento de invierno donde los jóvenes innovadores se sumergen en tecnología, robótica y desarrollo creativo durante las navidades.</p>
            <p data-lang="en">The best holiday gift! Winter camp where young innovators dive into technology, robotics, and creative development during Christmas break.</p>
            <div class="offering-footer">
              <span class="offering-meta">❄️ <span data-lang="es">Diciembre</span><span data-lang="en">December</span></span>
              <a href="/ofrecimientos/winter-camp" class="btn btn-primary">
                <span data-lang="es">Ver más</span><span data-lang="en">Learn more</span>
              </a>
            </div>
          </div>
        </div>

        <div class="offering-card offering-card-wro reveal reveal-delay-2">
          <div class="offering-img">
            <img src="/images/wro/IMG_1755.webp" alt="World Robot Olympiad WRO" loading="lazy" />
            <span class="offering-tag offering-tag-gold" data-lang="es">🌍 Internacional</span>
            <span class="offering-tag offering-tag-gold" data-lang="en">🌍 International</span>
          </div>
          <div class="offering-body">
            <h3>World Robot Olympiad (WRO)</h3>
            <p data-lang="es">Techno Inventors lleva equipos a la competencia de robótica más importante del mundo. Nuestros estudiantes representan a Puerto Rico en torneos internacionales ante países de todo el mundo.</p>
            <p data-lang="en">Techno Inventors sends teams to the world's most important robotics competition. Our students represent Puerto Rico in international tournaments against countries from around the world.</p>
            <div class="offering-footer">
              <span class="offering-meta">🏆 <span data-lang="es">Competencia Global</span><span data-lang="en">Global Competition</span></span>
              <a href="https://wro.pr/" target="_blank" rel="noopener" class="btn btn-gold">
                <span data-lang="es">Ver más</span><span data-lang="en">Learn more</span>
              </a>
            </div>
          </div>
        </div>

        <!-- ROW 3 -->
        <div class="offering-card offering-card-olimp reveal">
          <div class="offering-img">
            <img src="/images/olimpiadas/IMG_5248.webp" alt="Olimpiadas Regionales de Robótica" loading="lazy" />
            <span class="offering-tag offering-tag-orange" data-lang="es">🥇 Regional</span>
            <span class="offering-tag offering-tag-orange" data-lang="en">🥇 Regional</span>
          </div>
          <div class="offering-body">
            <h3 data-lang="es">Olimpiadas Regionales</h3>
            <h3 data-lang="en">Regional Olympiad</h3>
            <p data-lang="es">Competencias regionales de robótica donde nuestros equipos demuestran sus habilidades, estrategia y trabajo en equipo ante jueces y otras instituciones de Puerto Rico.</p>
            <p data-lang="en">Regional robotics competitions where our teams demonstrate their skills, strategy, and teamwork before judges and other institutions from Puerto Rico.</p>
            <div class="offering-footer">
              <span class="offering-meta">🤖 <span data-lang="es">Puerto Rico</span><span data-lang="en">Puerto Rico</span></span>
              <a href="https://wro.pr/" target="_blank" rel="noopener" class="btn btn-orange">
                <span data-lang="es">Ver más</span><span data-lang="en">Learn more</span>
              </a>
            </div>
          </div>
        </div>

        <div class="offering-card reveal reveal-delay-1">
          <div class="offering-img">
            <img src="/images/early-inventors/IMG_3261.webp" alt="Early Inventors Program" loading="lazy" />
            <span class="offering-tag" data-lang="es">Edades Tempranas</span>
