---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');
const posts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const featured = posts.filter(p => p.data.featured);
const rest = posts.filter(p => !p.data.featured);

const categories = ['noticias', 'programas', 'competencias', 'comunidad', 'tecnología'];
const categoriesEn: Record<string, string> = {
  noticias: 'News',
  programas: 'Programs',
  competencias: 'Competitions',
  comunidad: 'Community',
  tecnología: 'Technology',
};
---

<BaseLayout
  title="Blog | Techno Inventors"
  description="Noticias, historias de éxito y recursos educativos de Techno Inventors en Puerto Rico."
  ogTitle="Blog de Techno Inventors — Tecnología, Educación e Innovación"
  ogDescription="Noticias, historias de éxito y recursos educativos de Techno Inventors en Puerto Rico."
>
  <Header activePage="blog" />

  <!-- ===== BLOG HERO ===== -->
  <section class="blog-hero">
    <div class="container">
      <span class="section-tag" data-lang="es">Nuestro Blog</span>
      <span class="section-tag" data-lang="en">Our Blog</span>
      <h1>
        <span data-lang="es">Tecnología, Educación<br/><em>e Innovación</em></span>
        <span data-lang="en">Technology, Education<br/><em>&amp; Innovation</em></span>
      </h1>
      <p class="blog-hero-sub">
        <span data-lang="es">Noticias, proyectos y recursos para transformar comunidades a través del aprendizaje STEM.</span>
        <span data-lang="en">News, projects, and resources to transform communities through STEM learning.</span>
      </p>
    </div>
  </section>

  <!-- ===== MAIN CONTENT ===== -->
  <main class="blog-main container">

    <!-- FEATURED POST -->
    {featured.length > 0 && (
      <section class="blog-featured reveal">
        <h2 class="blog-section-title">
          <span data-lang="es">✨ Artículo Destacado</span>
          <span data-lang="en">✨ Featured Article</span>
        </h2>
        {featured.slice(0, 1).map(post => (
          <a href={`/blog/${post.slug}`} class="featured-card">
            <div class="featured-img">
              {post.data.heroImage
                ? <img src={post.data.heroImage} alt={post.data.title} loading="lazy" />
                : <div class="featured-img-placeholder"><span>📰</span></div>
              }
              <span class="featured-badge">
                <span data-lang="es">{post.data.category}</span>
                <span data-lang="en">{post.data.categoryEn ?? post.data.category}</span>
              </span>
            </div>
            <div class="featured-content">
              <time class="post-date">{post.data.pubDate.toLocaleDateString('es-PR', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
              <h3 class="featured-title">
                <span data-lang="es">{post.data.title}</span>
                <span data-lang="en">{post.data.titleEn ?? post.data.title}</span>
              </h3>
              <p class="featured-desc">
                <span data-lang="es">{post.data.description}</span>
                <span data-lang="en">{post.data.descriptionEn ?? post.data.description}</span>
              </p>
              <span class="read-more">
                <span data-lang="es">Leer artículo →</span>
                <span data-lang="en">Read article →</span>
              </span>
            </div>
          </a>
        ))}
      </section>
    )}

    <!-- CATEGORY FILTERS -->
    <section class="blog-filters reveal">
      <h2 class="blog-section-title">
        <span data-lang="es">Todos los artículos</span>
        <span data-lang="en">All articles</span>
      </h2>
      <div class="filter-pills">
        <button class="filter-pill active" data-filter="all">
          <span data-lang="es">Todos</span>
          <span data-lang="en">All</span>
        </button>
        {categories.map(cat => (
          <button class="filter-pill" data-filter={cat}>
            <span data-lang="es">{cat.charAt(0).toUpperCase() + cat.slice(1)}</span>
            <span data-lang="en">{categoriesEn[cat]}</span>
          </button>
        ))}
      </div>
    </section>

    <!-- POST GRID -->
    <section class="post-grid reveal">
      {rest.length === 0 && featured.length > 0 && (
        <p class="no-posts">
          <span data-lang="es">Próximamente más artículos…</span>
          <span data-lang="en">More articles coming soon…</span>
        </p>
      )}
      {[...featured.slice(1), ...rest].map(post => (
        <article class="post-card" data-category={post.data.category}>
          <a href={`/blog/${post.slug}`} class="post-card-link">
            <div class="post-img">
              {post.data.heroImage
                ? <img src={post.data.heroImage} alt={post.data.title} loading="lazy" />
                : <div class="post-img-placeholder"><span>📰</span></div>
              }
              <span class="post-cat-badge">
                <span data-lang="es">{post.data.category}</span>
                <span data-lang="en">{post.data.categoryEn ?? post.data.category}</span>
              </span>
            </div>
            <div class="post-body">
              <time class="post-date">{post.data.pubDate.toLocaleDateString('es-PR', { year: 'numeric', month: 'short', day: 'numeric' })}</time>
              <h3 class="post-title">
                <span data-lang="es">{post.data.title}</span>
                <span data-lang="en">{post.data.titleEn ?? post.data.title}</span>
              </h3>
              <p class="post-desc">
                <span data-lang="es">{post.data.description}</span>
                <span data-lang="en">{post.data.descriptionEn ?? post.data.description}</span>
              </p>
              <div class="post-footer">
                <span class="post-author">✍️ {post.data.author}</span>
                <span class="read-more-sm">
                  <span data-lang="es">Leer →</span>
                  <span data-lang="en">Read →</span>
                </span>
              </div>
            </div>
          </a>
        </article>
      ))}
    </section>

  </main>

  <!-- ===== BLOG CTA ===== -->
  <section class="blog-cta">
    <div class="container">
      <h2>
        <span data-lang="es">¿Listo para unirte a la revolución STEM?</span>
        <span data-lang="en">Ready to join the STEM revolution?</span>
      </h2>
      <p>
        <span data-lang="es">Inscribe a tu hijo o hija en nuestros programas y transforma su futuro.</span>
        <span data-lang="en">Enroll your child in our programs and transform their future.</span>
      </p>
      <a href="/#contact-cta" class="btn btn-primary">
        <span data-lang="es">🎓 Contactar Asesor Académico</span>
        <span data-lang="en">🎓 Contact Academic Advisor</span>
      </a>
    </div>
  </section>

  <Footer />
</BaseLayout>

<style>
/* ===== BLOG HERO ===== */
.blog-hero {
  background: linear-gradient(135deg, var(--navy) 0%, #0d1440 60%, #162060 100%);
  padding: 140px 0 80px;
  text-align: center;
  position: relative;
  overflow: hidden;
}
.blog-hero::before {
  content: '';
  position: absolute;
  inset: 0;
  background: radial-gradient(ellipse 60% 80% at 50% 0%, rgba(37,142,182,0.15) 0%, transparent 70%);
  pointer-events: none;
}
.blog-hero .section-tag {
  font-family: var(--font-display);
  font-size: 0.75rem;
  font-weight: 700;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--light-blue);
  background: rgba(136,215,247,0.12);
  border: 1px solid rgba(136,215,247,0.25);
  border-radius: 50px;
  padding: 6px 18px;
  display: inline-block;
  margin-bottom: 24px;
}
.blog-hero h1 {
  font-family: var(--font-display);
  font-size: clamp(2.2rem, 5vw, 3.8rem);
  font-weight: 900;
  color: var(--white);
  line-height: 1.1;
  margin-bottom: 20px;
}
.blog-hero h1 em {
  font-style: normal;
  background: linear-gradient(135deg, var(--blue) 0%, var(--light-blue) 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}
.blog-hero-sub {
  font-size: 1.1rem;
  color: rgba(255,255,255,0.75);
  max-width: 560px;
  margin: 0 auto;
  line-height: 1.7;
}

/* ===== BLOG MAIN ===== */
.blog-main {
  padding: 72px 0 80px;
}
.blog-section-title {
  font-family: var(--font-display);
  font-size: 1.1rem;
  font-weight: 700;
  color: var(--navy);
  margin-bottom: 28px;
  display: flex;
  align-items: center;
  gap: 10px;
}
.blog-section-title::after {
  content: '';
  flex: 1;
  height: 2px;
  background: linear-gradient(90deg, var(--blue) 0%, transparent 100%);
  border-radius: 2px;
}

/* ===== FEATURED CARD ===== */
.blog-featured {
  margin-bottom: 64px;
}
.featured-card {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 0;
  background: var(--white);
  border-radius: 20px;
  overflow: hidden;
  box-shadow: 0 8px 40px rgba(26,33,86,0.12);
  text-decoration: none;
  transition: transform 0.3s ease, box-shadow 0.3s ease;
}
.featured-card:hover {
  transform: translateY(-4px);
  box-shadow: 0 16px 56px rgba(26,33,86,0.18);
}
.featured-img {
  position: relative;
  min-height: 320px;
  overflow: hidden;
}
.featured-img img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.4s ease;
}
.featured-card:hover .featured-img img {
  transform: scale(1.04);
}
.featured-img-placeholder {
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, var(--navy), var(--blue));
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 4rem;
}
.featured-badge {
  position: absolute;
  top: 16px;
  left: 16px;
  background: var(--blue);
  color: var(--white);
  font-family: var(--font-display);
  font-size: 0.65rem;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  padding: 5px 12px;
  border-radius: 50px;
}
.featured-content {
  padding: 40px 44px;
  display: flex;
  flex-direction: column;
  justify-content: center;
}
.post-date {
  font-size: 0.8rem;
  color: var(--blue);
  font-weight: 600;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  display: block;
  margin-bottom: 14px;
}
.featured-title {
  font-family: var(--font-display);
  font-size: clamp(1.3rem, 2.2vw, 1.8rem);
  font-weight: 800;
  color: var(--navy);
  line-height: 1.25;
  margin-bottom: 16px;
}
.featured-desc {
  font-size: 1rem;
  color: var(--gray);
  line-height: 1.7;
  margin-bottom: 28px;
}
.read-more {
  font-family: var(--font-display);
  font-size: 0.85rem;
  font-weight: 700;
  color: var(--blue);
  letter-spacing: 0.05em;
  transition: gap 0.2s;
  display: inline-flex;
  align-items: center;
  gap: 4px;
}
.featured-card:hover .read-more {
  gap: 8px;
}

/* ===== FILTER PILLS ===== */
.blog-filters {
  margin-bottom: 40px;
}
.filter-pills {
  display: flex;
  gap: 10px;
  flex-wrap: wrap;
}
.filter-pill {
  font-family: var(--font-display);
  font-size: 0.75rem;
  font-weight: 600;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  padding: 8px 18px;
  border-radius: 50px;
  border: 2px solid var(--blue);
  background: transparent;
  color: var(--blue);
  cursor: pointer;
  transition: all 0.25s ease;
}
.filter-pill:hover,
.filter-pill.active {
  background: var(--blue);
  color: var(--white);
}

/* ===== POST GRID ===== */
.post-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
  gap: 28px;
  margin-bottom: 16px;
}
.no-posts {
  color: var(--gray);
  font-size: 1rem;
  text-align: center;
  padding: 48px;
  grid-column: 1 / -1;
}
.post-card {
  border-radius: 16px;
  overflow: hidden;
  background: var(--white);
  box-shadow: 0 4px 24px rgba(26,33,86,0.08);
  transition: transform 0.3s ease, box-shadow 0.3s ease;
}
.post-card:hover {
  transform: translateY(-4px);
  box-shadow: 0 12px 40px rgba(26,33,86,0.14);
}
.post-card-link {
  display: flex;
  flex-direction: column;
  height: 100%;
  text-decoration: none;
  color: inherit;
}
.post-img {
  position: relative;
  height: 200px;
  overflow: hidden;
}
.post-img img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.4s ease;
}
.post-card:hover .post-img img {
  transform: scale(1.05);
}
.post-img-placeholder {
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, var(--navy) 0%, var(--blue) 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 2.5rem;
}
.post-cat-badge {
  position: absolute;
  top: 12px;
  left: 12px;
  background: var(--navy);
  color: var(--white);
  font-family: var(--font-display);
  font-size: 0.6rem;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  padding: 4px 10px;
  border-radius: 50px;
}
.post-body {
  padding: 24px;
  display: flex;
  flex-direction: column;
  flex: 1;
}
.post-title {
  font-family: var(--font-display);
  font-size: 1.05rem;
  font-weight: 700;
  color: var(--navy);
  line-height: 1.35;
  margin-bottom: 10px;
}
.post-desc {
  font-size: 0.9rem;
  color: var(--gray);
  line-height: 1.6;
  flex: 1;
  margin-bottom: 16px;
}
.post-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-top: 1px solid rgba(26,33,86,0.06);
  padding-top: 14px;
}
.post-author {
  font-size: 0.8rem;
  color: var(--gray);
}
.read-more-sm {
  font-family: var(--font-display);
  font-size: 0.75rem;
  font-weight: 700;
  color: var(--blue);
  letter-spacing: 0.05em;
}

/* ===== BLOG CTA ===== */
.blog-cta {
  background: linear-gradient(135deg, var(--navy) 0%, #162060 100%);
  padding: 80px 0;
  text-align: center;
}
.blog-cta h2 {
  font-family: var(--font-display);
  font-size: clamp(1.6rem, 3.5vw, 2.4rem);
  font-weight: 800;
  color: var(--white);
  margin-bottom: 16px;
}
.blog-cta p {
  font-size: 1.05rem;
  color: rgba(255,255,255,0.75);
  margin-bottom: 36px;
}
.blog-cta .btn-primary {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  background: linear-gradient(135deg, var(--blue) 0%, #1a7aaa 100%);
  color: var(--white);
  padding: 16px 36px;
  border-radius: 50px;
  font-family: var(--font-display);
  font-size: 0.9rem;
  font-weight: 700;
  text-decoration: none;
  letter-spacing: 0.05em;
  transition: all 0.3s ease;
  box-shadow: 0 8px 32px rgba(37,142,182,0.4);
}
.blog-cta .btn-primary:hover {
  transform: translateY(-2px);
  box-shadow: 0 14px 44px rgba(37,142,182,0.55);
}

/* ===== RESPONSIVE ===== */
@media (max-width: 768px) {
  .blog-hero { padding: 120px 0 60px; }
  .featured-card { grid-template-columns: 1fr; }
  .featured-img { min-height: 220px; }
  .featured-content { padding: 28px 24px; }
  .post-grid { grid-template-columns: 1fr; }
}

/* ===== HIDDEN POSTS (filter JS) ===== */
.post-card.hidden { display: none; }
</style>

<script>
  // Category filter functionality
  const pills = document.querySelectorAll('.filter-pill');
  const cards = document.querySelectorAll<HTMLElement>('.post-card');

  pills.forEach(pill => {
    pill.addEventListener('click', () => {
      pills.forEach(p => p.classList.remove('active'));
      pill.classList.add('active');
      const filter = (pill as HTMLElement).dataset.filter;
      cards.forEach(card => {
        if (filter === 'all' || card.dataset.category === filter) {
          card.classList.remove('hidden');
        } else {
          card.classList.add('hidden');
        }
      });
    });
  });
</script>
