---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="Donaciones | Techno Inventors Puerto Rico"
  description="Apoya a Techno Inventors y transforma la educación STEM en Puerto Rico. Tu donación forma líderes tecnológicos del futuro a través del modelo eSTREAM."
  ogTitle="Donaciones | Techno Inventors Puerto Rico"
  ogDescription="Tu donación impulsa la educación eSTREAM en Puerto Rico. Apoya a los líderes del mañana."
>
  <Header activePage="donate" />

  <!-- ===== HERO ===== -->
  <section id="page-hero">
    <div class="hero-glow g1"></div>
    <div class="hero-glow g2"></div>
    <div class="container">
      <div class="hero-inner">
        <div class="hero-text">
          <div class="breadcrumb">
            <a href="/">Techno Inventors</a>
            <span>/</span>
            <span data-lang="es">Donaciones</span>
            <span data-lang="en">Donations</span>
          </div>
          <div class="trust-strip">
            <span class="trust-badge">
              <span class="trust-icon">🏛️</span>
              <span data-lang="es">Organización sin fines de lucro</span>
              <span data-lang="en">Nonprofit Organization</span>
            </span>
            <span class="trust-badge">
              <span class="trust-icon">✅</span>
              <span data-lang="es">Donación deducible de impuestos</span>
              <span data-lang="en">Tax-deductible donation</span>
            </span>
            <span class="trust-badge">
              <span class="trust-icon">🔒</span>
              <span data-lang="es">100% seguro y transparente</span>
              <span data-lang="en">100% secure &amp; transparent</span>
            </span>
          </div>
          <h1 class="hero-title">
            <span data-lang="es">Tu donación construye el <em>futuro de Puerto Rico</em></span>
            <span data-lang="en">Your donation builds the <em>future of Puerto Rico</em></span>
          </h1>
          <p class="hero-desc">
            <span data-lang="es">Techno Inventors es la única organización a nivel secundario en Puerto Rico que forma líderes tecnológicos a través del modelo educativo eSTREAM. Cada dólar donado financia directamente programas, becas y recursos para jóvenes talentosos de nuestra isla.</span>
            <span data-lang="en">Techno Inventors is the only secondary-level organization in Puerto Rico training technology leaders through the eSTREAM model. Every dollar donated directly funds programs, scholarships, and resources for talented young people on our island.</span>
          </p>
          <div class="hero-actions">
            <a href="#donate-box" class="btn btn-donate btn-lg">
              <span data-lang="es">💚 Hacer una Donación</span>
              <span data-lang="en">💚 Make a Donation</span>
            </a>
            <a href="#problema" class="btn btn-outline-dark">
              <span data-lang="es">Ver el impacto →</span>
              <span data-lang="en">See the impact →</span>
            </a>
          </div>
          <p class="hero-micro">
            <span data-lang="es">🕑 Donar toma menos de 2 minutos · Tu confianza es nuestra mayor recompensa</span>
            <span data-lang="en">🕑 Donating takes less than 2 minutes · Your trust is our greatest reward</span>
          </p>
        </div>
        <div class="hero-img-wrap">
          <img src="/images/olimpiadas/IMG_5708.webp" alt="Techno Inventors students" loading="eager" />
          <div class="hero-img-badge">
            <span class="badge-num">35,753+</span>
            <span data-lang="es">jóvenes impactados</span>
            <span data-lang="en">youth impacted</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== IMPACT TICKER ===== -->
  <div id="impact-ticker">
    <div class="container">
      <div class="ticker-grid">
        <div class="ticker-item">
          <span class="ticker-num" data-count="35753">0</span>
          <span class="ticker-lbl" data-lang="es">Estudiantes Impactados</span>
          <span class="ticker-lbl" data-lang="en">Students Impacted</span>
        </div>
        <div class="ticker-item">
          <span class="ticker-num" data-count="8894">0</span>
          <span class="ticker-lbl" data-lang="es">Horas de Voluntariado</span>
          <span class="ticker-lbl" data-lang="en">Volunteer Hours</span>
        </div>
        <div class="ticker-item">
          <span class="ticker-num" data-count="73">0</span>
          <span class="ticker-lbl" data-lang="es">Instituciones Aliadas</span>
          <span class="ticker-lbl" data-lang="en">Partner Institutions</span>
        </div>
        <div class="ticker-item">
          <span class="ticker-num" data-count="10">0</span>
          <span class="ticker-lbl" data-lang="es">Años de Impacto</span>
          <span class="ticker-lbl" data-lang="en">Years of Impact</span>
        </div>
      </div>
    </div>
  </div>

  <!-- ===== ¿POR QUÉ NOSOTROS? ===== -->
  <section id="why-us" class="section">
    <div class="container">
      <div class="why-grid">
        <div class="why-img-stack reveal">
          <img src="/images/early-inventors/IMG_6182.webp" alt="Students" class="img-main" loading="lazy" />
          <img src="/images/olimpiadas/IMG_5874.webp" alt="Competencia de robótica" class="img-sm img-sm-1" loading="lazy" />
          <img src="/images/wro/IMG_1622.webp" alt="WRO Robotics" class="img-sm img-sm-2" loading="lazy" />
        </div>
        <div class="why-text reveal">
          <div class="cert-badge">
            <span class="cert-icon">🏛️</span>
            <div>
              <strong data-lang="es">Organización Sin Fines de Lucro</strong>
              <strong data-lang="en">Certified Nonprofit Organization</strong>
              <span data-lang="es">Tu donación puede ser deducible de impuestos</span>
              <span data-lang="en">Your donation may be tax-deductible</span>
            </div>
          </div>
          <span class="section-tag" data-lang="es">¿Por qué nosotros?</span>
          <span class="section-tag" data-lang="en">Why us?</span>
          <h2 class="section-title" data-lang="es">Una inversión directa en el capital humano de Puerto Rico</h2>
          <h2 class="section-title" data-lang="en">A direct investment in Puerto Rico's human capital</h2>
          <p data-lang="es">Techno Inventors es la única organización a nivel secundario (6to.–12mo. grado) en Puerto Rico que ofrece aprendizaje para el desarrollo de líderes en la nueva economía del conocimiento a través del modelo educativo eSTREAM (eSports, Ciencias, Tecnología, Robótica, Ingeniería, Arte y Matemáticas).</p>
          <p data-lang="en">Techno Inventors is the only secondary-level organization (grades 6–12) in Puerto Rico offering education for developing leaders in the new knowledge economy through the eSTREAM educational model (eSports, Science, Technology, Robotics, Engineering, Arts and Mathematics).</p>
          <p class="why-sub" data-lang="es">Con sede en Puerto Rico y fundada por el Ing. César Cabrera, hemos impactado a más de 35,753 jóvenes, formado alianzas con 73 organizaciones y acumulado más de 8,894 horas de servicio voluntario. Tu apoyo nos permite continuar transformando vidas a través de la educación tecnológica de vanguardia.</p>
          <p class="why-sub" data-lang="en">Based in Puerto Rico and founded by Eng. César Cabrera, we have impacted over 35,753 youth, forged alliances with 73 organizations, and accumulated over 8,894 volunteer service hours. Your support allows us to continue transforming lives through cutting-edge technology education.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== DATOS DE INTERÉS ===== -->
  <section id="datos" class="section section-alt">
    <div class="container">
      <div class="text-center reveal">
        <span class="section-tag" data-lang="es">Datos de Interés</span>
        <span class="section-tag" data-lang="en">Key Facts</span>
        <h2 class="section-title" data-lang="es">El impacto de tu donación en números</h2>
        <h2 class="section-title" data-lang="en">The impact of your donation in numbers</h2>
      </div>
      <div class="datos-grid">
        <div class="dato-item reveal">
          <div class="dato-check">✓</div>
          <p class="dato-text" data-lang="es"><strong>+35,753 participantes</strong> han pasado por los programas de Techno Inventors desde su fundación.</p>
          <p class="dato-text" data-lang="en"><strong>+35,753 participants</strong> have gone through Techno Inventors programs since its founding.</p>
        </div>
        <div class="dato-item reveal">
          <div class="dato-check">✓</div>
          <p class="dato-text" data-lang="es"><strong>Puerto Rico produce menos del 1%</strong> de los ingenieros que necesita para satisfacer la demanda local de talento tecnológico.</p>
          <p class="dato-text" data-lang="en"><strong>Puerto Rico produces less than 1%</strong> of the engineers it needs to meet local technology talent demand.</p>
        </div>
        <div class="dato-item reveal">
          <div class="dato-check">✓</div>
          <p class="dato-text" data-lang="es"><strong>Solo el 26% de los estudiantes</strong> de cuarto grado en PR obtienen una calificación "Competente" o superior en matemáticas según el Nation's Report Card.</p>
          <p class="dato-text" data-lang="en"><strong>Only 26% of 4th grade students</strong> in PR score "Proficient" or above in math according to the Nation's Report Card.</p>
        </div>
        <div class="dato-item reveal">
          <div class="dato-check">✓</div>
          <p class="dato-text" data-lang="es"><strong>El 73% de las ocupaciones</strong> de mayor crecimiento en los próximos años requerirán habilidades en ciencias, tecnología, ingeniería o matemáticas.</p>
          <p class="dato-text" data-lang="en"><strong>73% of the fastest-growing occupations</strong> over the coming years will require skills in science, technology, engineering or mathematics.</p>
        </div>
        <div class="dato-item reveal">
          <div class="dato-check">✓</div>
          <p class="dato-text" data-lang="es"><strong>Participantes en Summer STEMulate</strong> (NASA STEM): 3,456 estudiantes de comunidades subatendidas han accedido a experiencias STEM de clase mundial.</p>
          <p class="dato-text" data-lang="en"><strong>Summer STEMulate participants</strong> (NASA STEM): 3,456 students from underserved communities have accessed world-class STEM experiences.</p>
        </div>
        <div class="dato-item reveal">
          <div class="dato-check">✓</div>
          <p class="dato-text" data-lang="es"><strong>Representación Internacional:</strong> Equipos de Techno Inventors han competido en la World Robot Olympiad y otros torneos globales representando a Puerto Rico con orgullo.</p>
          <p class="dato-text" data-lang="en"><strong>International Representation:</strong> Techno Inventors teams have competed at the World Robot Olympiad and other global tournaments, proudly representing Puerto Rico.</p>
        </div>
        <div class="dato-item reveal">
          <div class="dato-check">✓</div>
          <p class="dato-text" data-lang="es"><strong>Alianzas con 73 organizaciones</strong> incluyendo universidades, corporaciones tecnológicas, escuelas y entidades gubernamentales en Puerto Rico y el mundo.</p>
          <p class="dato-text" data-lang="en"><strong>Alliances with 73 organizations</strong> including universities, technology corporations, schools, and governmental entities in Puerto Rico and worldwide.</p>
        </div>
        <div class="dato-item reveal">
          <div class="dato-check">✓</div>
          <p class="dato-text" data-lang="es"><strong>Modelo eSTREAM único:</strong> Integración de eSports, Ciencias, Tecnología, Robótica, Ingeniería, Arte y Matemáticas en un currículo vivencial que desarrolla líderes integrales.</p>
          <p class="dato-text" data-lang="en"><strong>Unique eSTREAM model:</strong> Integration of eSports, Science, Technology, Robotics, Engineering, Arts and Mathematics into an experiential curriculum that develops well-rounded leaders.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== DONATION BOX ===== -->
  <section id="donate-box">
    <div class="container">
      <div class="donate-inner reveal">
        <div class="donate-header">
          <span class="section-tag section-tag-green" data-lang="es">Haz tu donación hoy</span>
          <span class="section-tag section-tag-green" data-lang="en">Make your donation today</span>
          <h2 data-lang="es">Tu donación transforma vidas en Puerto Rico</h2>
          <h2 data-lang="en">Your donation transforms lives in Puerto Rico</h2>
          <p data-lang="es">Cada contribución, sin importar su tamaño, cambia la vida de un joven inventor en Puerto Rico.</p>
          <p data-lang="en">Every contribution, regardless of size, changes the life of a young inventor in Puerto Rico.</p>
        </div>
        <a href="mailto:info@technoinventors.com?subject=Donaci%C3%B3n%20a%20Techno%20Inventors&body=Hola%2C%20deseo%20realizar%20una%20donaci%C3%B3n%20a%20Techno%20Inventors.%20Por%20favor%20ind%C3%ADquenme%20los%20pasos%20para%20completar%20el%20proceso." class="btn btn-donate btn-donate-big" id="donate-btn">
          <span data-lang="es">💚 Proceder con mi donación</span>
          <span data-lang="en">💚 Proceed with my donation</span>
        </a>
        <div class="donate-trust-row">
          <span>🔒 <span data-lang="es">Proceso seguro</span><span data-lang="en">Secure process</span></span>
          <span>🏛️ <span data-lang="es">Sin fines de lucro</span><span data-lang="en">Nonprofit</span></span>
          <span>📊 <span data-lang="es">100% transparente</span><span data-lang="en">100% transparent</span></span>
          <span>✅ <span data-lang="es">Deducible de impuestos</span><span data-lang="en">Tax-deductible</span></span>
        </div>
        <p class="donate-note" data-lang="es">Para donaciones corporativas, patrocinios o más información sobre deducibilidad fiscal, contáctanos en <a href="mailto:info@technoinventors.com">info@technoinventors.com</a> o al <a href="tel:+15557117316">+1 (555) 711-7316</a>.</p>
        <p class="donate-note" data-lang="en">For corporate donations, sponsorships, or more information on tax deductibility, contact us at <a href="mailto:info@technoinventors.com">info@technoinventors.com</a> or <a href="tel:+15557117316">+1 (555) 711-7316</a>.</p>
      </div>
    </div>
  </section>

  <!-- ===== PROBLEMA / NECESIDAD ===== -->
  <section id="problema" class="section section-dark">
    <div class="container">
      <div class="problema-grid">
        <div class="problema-text reveal">
          <span class="section-tag section-tag-light" data-lang="es">Problema / Necesidad</span>
          <span class="section-tag section-tag-light" data-lang="en">Problem / Need</span>
          <h2 class="section-title section-title-light" data-lang="es">Puerto Rico enfrenta una brecha crítica en talento STEM</h2>
          <h2 class="section-title section-title-light" data-lang="en">Puerto Rico faces a critical STEM talent gap</h2>
          <p data-lang="es">Techno Inventors aborda de manera urgente la necesidad de mejorar la educación STEM en Puerto Rico, donde la falta de preparación técnica limita las oportunidades económicas de nuestra juventud y el desarrollo de la isla.</p>
          <p data-lang="en">Techno Inventors urgently addresses the need to improve STEM education in Puerto Rico, where lack of technical preparation limits the economic opportunities of our youth and the development of the island.</p>
          <p class="problema-p" data-lang="es">La reducción del número de estudiantes en PR —más del 27% en la última década— ha impactado directamente el financiamiento de las escuelas. En consecuencia, el acceso a programas de tecnología y robótica se ha reducido drásticamente. Nuestro modelo llena ese vacío directamente en las comunidades que más lo necesitan.</p>
          <p class="problema-p" data-lang="en">The reduction in the number of students in PR — more than 27% over the last decade — has directly impacted school funding. As a result, access to technology and robotics programs has been drastically reduced. Our model fills that gap directly in the communities that need it most.</p>
          <p class="problema-p" data-lang="es">Además, las estadísticas del Nation's Report Card indican que entre el 55% y 77% de los estudiantes de cuarto y octavo grado en PR no alcanzan el nivel mínimo de competencia en matemáticas. Techno Inventors actúa como puente entre el sistema educativo tradicional y las demandas del mercado laboral del siglo XXI.</p>
          <p class="problema-p" data-lang="en">Furthermore, Nation's Report Card statistics indicate that between 55% and 77% of 4th and 8th grade students in PR do not reach the minimum proficiency level in mathematics. Techno Inventors acts as a bridge between the traditional education system and the demands of the 21st-century labor market.</p>
        </div>
        <div class="problema-stats reveal">
          <div class="pstat">
            <span class="pstat-num">77%</span>
            <p class="pstat-desc" data-lang="es">de estudiantes de 8vo grado en PR no alcanzan el nivel mínimo de competencia en matemáticas (Nation's Report Card)</p>
            <p class="pstat-desc" data-lang="en">of 8th grade students in PR do not reach minimum math proficiency (Nation's Report Card)</p>
          </div>
          <div class="pstat">
            <span class="pstat-num">27%</span>
            <p class="pstat-desc" data-lang="es">reducción en la matrícula estudiantil en PR durante la última década, afectando el financiamiento de programas STEM</p>
            <p class="pstat-desc" data-lang="en">reduction in student enrollment in PR over the last decade, affecting STEM program funding</p>
          </div>
          <div class="pstat">
            <span class="pstat-num">&lt;1%</span>
            <p class="pstat-desc" data-lang="es">de los ingenieros que Puerto Rico necesita son producidos localmente para satisfacer la demanda de la nueva economía</p>
            <p class="pstat-desc" data-lang="en">of engineers Puerto Rico needs are produced locally to meet new economy demand</p>
          </div>
          <div class="pstat">
            <span class="pstat-num">73%</span>
            <p class="pstat-desc" data-lang="es">de las ocupaciones de mayor crecimiento requerirán formación STEM en los próximos años</p>
            <p class="pstat-desc" data-lang="en">of the fastest-growing occupations will require STEM training in the coming years</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== DISEÑO DEL PROGRAMA ===== -->
  <section id="programa" class="section">
    <div class="container">
      <div class="text-center reveal">
        <span class="section-tag" data-lang="es">Diseño del Programa</span>
        <span class="section-tag" data-lang="en">Program Design</span>
        <h2 class="section-title" data-lang="es">Cómo transformamos cada donación en impacto real</h2>
        <h2 class="section-title" data-lang="en">How we turn every donation into real impact</h2>
        <p class="section-subtitle" data-lang="es">Nuestro modelo eSTREAM integra eSports, Ciencias, Tecnología, Robótica, Ingeniería, Arte y Matemáticas en un currículo práctico, inmersivo y orientado a competencias reales que preparan a los jóvenes para el mundo laboral del futuro.</p>
        <p class="section-subtitle" data-lang="en">Our eSTREAM model integrates eSports, Science, Technology, Robotics, Engineering, Arts and Mathematics into a practical, immersive curriculum oriented toward real competencies that prepare youth for the future labor market.</p>
      </div>
      <div class="programa-steps">
        <div class="step-card reveal">
          <div class="step-icon">🤖</div>
          <div class="step-num">1</div>
          <h3 data-lang="es">Aprendizaje Práctico</h3>
          <h3 data-lang="en">Hands-On Learning</h3>
          <p data-lang="es">Los estudiantes construyen, programan y compiten. Aprenden robótica, desarrollo de videojuegos, IA, realidad virtual y más con equipos de tecnología de vanguardia.</p>
          <p data-lang="en">Students build, program and compete. They learn robotics, video game development, AI, virtual reality and more using cutting-edge technology equipment.</p>
        </div>
        <div class="step-card reveal">
          <div class="step-icon">🏆</div>
          <div class="step-num">2</div>
          <h3 data-lang="es">Competencias Reales</h3>
          <h3 data-lang="en">Real Competitions</h3>
          <p data-lang="es">Participamos en torneos locales, nacionales e internacionales como la World Robot Olympiad, donde nuestros estudiantes representan a Puerto Rico con orgullo y excelencia.</p>
          <p data-lang="en">We compete in local, national and international tournaments such as the World Robot Olympiad, where our students represent Puerto Rico with pride and excellence.</p>
        </div>
        <div class="step-card reveal">
          <div class="step-icon">🌐</div>
          <div class="step-num">3</div>
          <h3 data-lang="es">Red de Liderazgo</h3>
          <h3 data-lang="en">Leadership Network</h3>
          <p data-lang="es">Conectamos a los jóvenes con mentores, universidades y empresas tecnológicas para construir trayectorias profesionales sólidas desde temprana edad.</p>
          <p data-lang="en">We connect youth with mentors, universities and technology companies to build solid career paths from an early age.</p>
        </div>
      </div>
      <div class="programa-lista reveal">
        <h3 class="programa-list-title" data-lang="es">Áreas de Conocimiento del Modelo eSTREAM:</h3>
        <h3 class="programa-list-title" data-lang="en">eSTREAM Model Knowledge Areas:</h3>
        <div class="plist">
          <div class="plist-item"><div class="plist-dot"></div><span data-lang="es">Programación de computadoras y robótica avanzada</span><span data-lang="en">Computer programming and advanced robotics</span></div>
          <div class="plist-item"><div class="plist-dot"></div><span data-lang="es">Mecánica y electrónica aplicada</span><span data-lang="en">Applied mechanics and electronics</span></div>
          <div class="plist-item"><div class="plist-dot"></div><span data-lang="es">Animación digital y diseño gráfico</span><span data-lang="en">Digital animation and graphic design</span></div>
          <div class="plist-item"><div class="plist-dot"></div><span data-lang="es">Desarrollo de videojuegos y realidad virtual</span><span data-lang="en">Video game development and virtual reality</span></div>
          <div class="plist-item"><div class="plist-dot"></div><span data-lang="es">eSports y desarrollo de liderazgo</span><span data-lang="en">eSports and leadership development</span></div>
          <div class="plist-item"><div class="plist-dot"></div><span data-lang="es">Inteligencia artificial e impresión 3D</span><span data-lang="en">Artificial intelligence and 3D printing</span></div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== CÓMO FUNCIONA ===== -->
  <section id="como-funciona" class="section section-alt">
    <div class="container">
      <div class="text-center reveal">
        <span class="section-tag" data-lang="es">¿Cómo Funciona?</span>
        <span class="section-tag" data-lang="en">How Does It Work?</span>
        <h2 class="section-title" data-lang="es">Del primer contacto a la transformación del futuro</h2>
        <h2 class="section-title" data-lang="en">From first contact to transforming the future</h2>
      </div>
      <div class="timeline">
        <div class="timeline-step reveal">
          <div class="timeline-num">01</div>
          <div class="timeline-content">
            <h4 data-lang="es">Haces tu Donación</h4>
            <h4 data-lang="en">You Make Your Donation</h4>
            <p data-lang="es">Seleccionas el monto y realizas tu aportación de forma segura. Recibirás una confirmación con el impacto estimado de tu donación.</p>
            <p data-lang="en">You select the amount and make your contribution securely. You will receive a confirmation with the estimated impact of your donation.</p>
          </div>
        </div>
        <div class="timeline-step reveal">
          <div class="timeline-num">02</div>
          <div class="timeline-content">
            <h4 data-lang="es">Los Fondos se Destinan a Programas</h4>
            <h4 data-lang="en">Funds Go to Programs</h4>
            <p data-lang="es">Tu donación se asigna directamente a programas educativos: materiales, equipos tecnológicos, becas estudiantiles y capacitación de instructores.</p>
            <p data-lang="en">Your donation is assigned directly to educational programs: materials, technology equipment, student scholarships, and instructor training.</p>
          </div>
        </div>
        <div class="timeline-step reveal">
          <div class="timeline-num">03</div>
          <div class="timeline-content">
            <h4 data-lang="es">Los Jóvenes Aprenden y Crecen</h4>
            <h4 data-lang="en">Youth Learn and Grow</h4>
            <p data-lang="es">Estudiantes de todo Puerto Rico acceden a programas After-School, Clubs, Campamentos y talleres que transforman su relación con la tecnología y el conocimiento.</p>
            <p data-lang="en">Students from across Puerto Rico access After-School programs, Clubs, Camps and workshops that transform their relationship with technology and knowledge.</p>
          </div>
        </div>
        <div class="timeline-step reveal">
