---
export interface Props {
  activePage?: string;
}
const { activePage = '' } = Astro.props;
---

<!-- ===== ANNOUNCEMENT BAR ===== -->
<div id="announce-bar" role="banner">
  <span class="announce-badge" data-lang="es">¡Inscripciones Abiertas!</span>
  <span class="announce-badge" data-lang="en">Enrollment Open!</span>
  <span data-lang="es">🤖 Las plazas para el <strong>Spring Break Camp</strong> están disponibles — ¡cupos limitados!</span>
  <span data-lang="en">🤖 <strong>Spring Break Camp</strong> spots are now available — limited spaces!</span>
  <a href="#contact-cta" data-lang="es">Reserva tu lugar →</a>
  <a href="#contact-cta" data-lang="en">Reserve your spot →</a>
  <button id="announce-close" aria-label="Close announcement">&times;</button>
</div>

<!-- ===== TOP BAR ===== -->
<div id="top-bar">
  <div class="container inner">
    <span>📍 Puerto Rico &nbsp;|&nbsp; <a href="mailto:info@technoinventors.com">info@technoinventors.com</a> &nbsp;|&nbsp; <a href="tel:+15557117316">+1 (555) 711-7316</a></span>
    <div style="display:flex;gap:16px;align-items:center;">
      <div class="socials">
        <a href="https://facebook.com/technoinventors" target="_blank" rel="noopener" aria-label="Facebook">
          <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
        </a>
        <a href="https://instagram.com/technoinventors" target="_blank" rel="noopener" aria-label="Instagram">
          <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/></svg>
        </a>
        <a href="https://linkedin.com/company/technoinventors" target="_blank" rel="noopener" aria-label="LinkedIn">
          <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6zM2 9h4v12H2z"/><circle cx="4" cy="4" r="2"/></svg>
        </a>
        <a href="https://youtube.com/@technoinventors123" target="_blank" rel="noopener" aria-label="YouTube">
          <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46a2.78 2.78 0 0 0-1.95 1.96A29 29 0 0 0 1 12a29 29 0 0 0 .46 5.58A2.78 2.78 0 0 0 3.41 19.6C5.12 20 12 20 12 20s6.88 0 8.59-.46a2.78 2.78 0 0 0 1.95-1.95A29 29 0 0 0 23 12a29 29 0 0 0-.46-5.58z"/><polygon points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02"/></svg>
        </a>
        <a href="https://twitter.com/technoinventors" target="_blank" rel="noopener" aria-label="X / Twitter">
          <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.73-8.835L1.254 2.25H8.08l4.259 5.63zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
        </a>
        <a href="https://discord.gg/technoinventors" target="_blank" rel="noopener" aria-label="Discord">
          <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03z"/></svg>
        </a>
      </div>
      <div class="lang-switch">
        <button class="lang-btn active" id="btn-es" onclick="setLang('es')">ES</button>
        <button class="lang-btn" id="btn-en" onclick="setLang('en')">EN</button>
      </div>
    </div>
  </div>
</div>

<!-- ===== NAVBAR ===== -->
<nav id="navbar" role="navigation" aria-label="Main navigation">
  <div class="nav-inner">
    <a href="/" class="nav-logo" aria-label="Techno Inventors Home">
      <img src="/Brandbook/Logos/Logo_1.webp" alt="Techno Inventors Logo" loading="eager" />
    </a>
    <ul class="nav-menu">
      <li>
        <a href="/#about" class={`nav-link${activePage === 'about' ? ' active' : ''}`} data-lang="es">Nosotros</a>
        <a href="/#about" class={`nav-link${activePage === 'about' ? ' active' : ''}`} data-lang="en">About</a>
      </li>
      <li>
        <a href="/#offerings" class={`nav-link${activePage === 'offerings' ? ' active' : ''}`} data-lang="es">Ofrecimientos</a>
        <a href="/#offerings" class={`nav-link${activePage === 'offerings' ? ' active' : ''}`} data-lang="en">Programs</a>
      </li>
      <li>
        <a href="/#gallery" class="nav-link" data-lang="es">Galería</a>
        <a href="/#gallery" class="nav-link" data-lang="en">Gallery</a>
      </li>
      <li>
        <a href="/#alliances" class="nav-link" data-lang="es">Alianzas</a>
        <a href="/#alliances" class="nav-link" data-lang="en">Alliances</a>
      </li>
      <li>
        <a href="/#faq" class="nav-link">FAQ</a>
      </li>
      <li>
        <a href="/blog" class={`nav-link${activePage === 'blog' ? ' active' : ''}`} data-lang="es">Blog</a>
        <a href="/blog" class={`nav-link${activePage === 'blog' ? ' active' : ''}`} data-lang="en">Blog</a>
      </li>
      <li>
        <a href="/donaciones" class={`nav-link${activePage === 'donaciones' ? ' active' : ''}`} data-lang="es">Donaciones</a>
        <a href="/donaciones" class={`nav-link${activePage === 'donaciones' ? ' active' : ''}`} data-lang="en">Donate</a>
      </li>
    </ul>
    <div class="nav-actions">
      <a href="/#contact-cta" class="btn btn-cta">
        <span data-lang="es">🎓 Contactar Asesor Académico</span>
        <span data-lang="en">🎓 Contact Academic Advisor</span>
      </a>
      <button class="hamburger" id="hamburger-btn" aria-label="Toggle menu" aria-expanded="false">
        <div class="hb-lines"><span></span><span></span><span></span></div>
      </button>
    </div>
  </div>
</nav>

<!-- ===== MOBILE MENU ===== -->
<div id="mobile-menu" role="dialog" aria-modal="true" aria-label="Mobile navigation">
  <div class="mobile-menu-header">
    <img src="/Brandbook/Logos/Logo_2.webp" alt="Techno Inventors" loading="eager" />
    <button id="mobile-close" aria-label="Close menu">
      <svg viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
  </div>
  <div class="mobile-nav-links">
    <a href="/#about" class="mobile-nav-link" data-lang="es">Nosotros</a>
    <a href="/#about" class="mobile-nav-link" data-lang="en">About Us</a>
    <a href="/#offerings" class="mobile-nav-link" data-lang="es">Ofrecimientos</a>
    <a href="/#offerings" class="mobile-nav-link" data-lang="en">Programs</a>
    <a href="/#gallery" class="mobile-nav-link" data-lang="es">Galería</a>
    <a href="/#gallery" class="mobile-nav-link" data-lang="en">Gallery</a>
    <a href="/#alliances" class="mobile-nav-link" data-lang="es">Alianzas</a>
    <a href="/#alliances" class="mobile-nav-link" data-lang="en">Alliances</a>
    <a href="/#faq" class="mobile-nav-link">FAQ</a>
    <a href="/blog" class="mobile-nav-link" data-lang="es">Blog</a>
    <a href="/blog" class="mobile-nav-link" data-lang="en">Blog</a>
    <a href="/donaciones" class="mobile-nav-link" data-lang="es">Donaciones</a>
    <a href="/donaciones" class="mobile-nav-link" data-lang="en">Donate</a>
  </div>
  <div class="mobile-menu-footer">
    <a href="/#contact-cta" class="btn btn-cta" style="width:100%;justify-content:center;font-size:0.9rem;">
      <span data-lang="es">🎓 Contactar Asesor Académico</span>
      <span data-lang="en">🎓 Contact Academic Advisor</span>
    </a>
  </div>
</div>
